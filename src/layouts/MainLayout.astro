---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { ACCESS_CONFIG } from '../config/access';

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
  protectedPage?: boolean;
}

const {
  title,
  description = 'Premium cocopeat and coconut fiber products from Indonesia, processed to export standards for sustainable agriculture worldwide.',
  currentPage = '',
  protectedPage = true,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
---

<!DOCTYPE html>
<html lang="en" data-auth-pending={protectedPage ? 'true' : 'false'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="cocopeat, coconut fiber, coir, export, Indonesia, sustainable agriculture, growing media, hydroponics" />
    <meta name="author" content="INDOCOCOPEAT - PT. Abbasy Jaya Makmur" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:site_name" content="INDOCOCOPEAT" />

    <link rel="canonical" href={canonicalUrl.toString()} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    {protectedPage && (
      <style is:inline>
        html[data-auth-pending="true"] body {
          visibility: hidden;
        }
      </style>
    )}

    <script is:inline define:vars={{
      protectedPage,
      sessionKey: ACCESS_CONFIG.sessionKey,
      sessionDuration: ACCESS_CONFIG.sessionDuration,
    }}>
      (function () {
        if (!protectedPage) {
          document.documentElement.removeAttribute('data-auth-pending');
          return;
        }

        try {
          var rawSession = localStorage.getItem(sessionKey);
          var targetPath = window.location.pathname + window.location.search;

          if (!rawSession) {
            window.location.replace('/access?redirect=' + encodeURIComponent(targetPath));
            return;
          }

          var session = JSON.parse(rawSession);
          var isExpired = Date.now() - Number(session.timestamp || 0) > sessionDuration;

          if (!session.authenticated || isExpired) {
            localStorage.removeItem(sessionKey);
            window.location.replace('/access?redirect=' + encodeURIComponent(targetPath));
            return;
          }

          document.documentElement.removeAttribute('data-auth-pending');
        } catch (error) {
          localStorage.removeItem(sessionKey);
          window.location.replace('/access?redirect=' + encodeURIComponent(window.location.pathname + window.location.search));
        }
      })();
    </script>
  </head>
  <body>
    <Navbar currentPage={currentPage} />

    <slot />

    <Footer />

    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        var observer = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

        document.querySelectorAll('.reveal').forEach(function (el) {
          observer.observe(el);
        });
      });
    </script>
  </body>
</html>
