---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  currentPage?: string;
}

const { title, description = 'INDOCOCOPEAT — Premium cocopeat and coconut fiber products from Indonesia. Export quality sustainable growing media for international markets.', currentPage = '' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta name="keywords" content="cocopeat, coconut fiber, coir, export, Indonesia, sustainable agriculture, growing media, hydroponics" />
  <meta name="author" content="INDOCOCOPEAT - PT. Abbasy Jaya Makmur" />
  
  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="en_US" />
  
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
</head>
<body>
  <script is:inline>
    // Access validation check — redirect to login if not authenticated
    (function() {
      var sessionData = localStorage.getItem('indococopeat_access');
      if (!sessionData) {
        window.location.href = '/';
        return;
      }
      try {
        var parsed = JSON.parse(sessionData);
        var now = Date.now();
        if (!parsed.authenticated || (now - parsed.timestamp) > 86400000) {
          localStorage.removeItem('indococopeat_access');
          window.location.href = '/';
        }
      } catch (e) {
        localStorage.removeItem('indococopeat_access');
        window.location.href = '/';
      }
    })();
  </script>
  
  <Navbar currentPage={currentPage} />
  
  <slot />
  
  <Footer />
  
  <!-- Scroll reveal observer script -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
      
      document.querySelectorAll('.reveal').forEach(function(el) {
        observer.observe(el);
      });
    });
  </script>
</body>
</html>
