---
export interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props;
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const links = [
  { label: 'Home', href: '/', key: 'home' },
  { label: 'Products', href: '/products', key: 'products' },
  { label: 'Farm', href: '/farm', key: 'farm' },
  { label: 'Contact', href: '/contact', key: 'contact' },
];

const isActive = (href: string, key: string) =>
  currentPage === key || pathname === href;
---

<nav class="navbar" id="navbar">
  <div class="container navbar__container">
    <a href="/" class="navbar__logo" aria-label="INDOCOCOPEAT home">
      <div class="navbar__logo-icon" aria-hidden="true">IC</div>
      <div class="navbar__logo-text">
        <span class="navbar__logo-main">INDOCOCOPEAT</span>
        <span class="navbar__logo-sub">PT. ABBASY JAYA MAKMUR</span>
      </div>
    </a>

    <ul class="navbar__links hidden md-flex">
      {links.map((link) => (
        <li>
          <a href={link.href} class={isActive(link.href, link.key) ? 'active' : ''}>{link.label}</a>
        </li>
      ))}
    </ul>

    <div class="navbar__actions hidden md-flex">
      <div class="lang-selector" aria-label="Current language">EN</div>
      <a href="/contact" class="btn btn--primary navbar__cta">Get in Touch &rarr;</a>
      <button id="logoutBtn" class="logout-btn" type="button">Exit Private View</button>
    </div>

    <button class="navbar__mobile-toggle md-hidden" id="mobileToggle" type="button" aria-label="Toggle menu" aria-expanded="false">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobileMenu">
    <div class="mobile-menu__inner">
      <ul class="mobile-menu__links">
        {links.map((link) => (
          <li>
            <a href={link.href} class={isActive(link.href, link.key) ? 'active' : ''}>{link.label}</a>
          </li>
        ))}
      </ul>
      <div class="mobile-menu__actions">
        <a href="/contact" class="btn btn--primary">Get in Touch</a>
        <button id="mobileLogoutBtn" class="btn btn--ghost" type="button">Logout Access</button>
      </div>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: var(--navbar-height);
    background-color: rgba(253, 251, 247, 0.94);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--color-border);
    z-index: var(--z-sticky);
    transition: box-shadow var(--transition-base), height var(--transition-base);
  }

  .navbar.scrolled {
    box-shadow: var(--shadow-sm);
    height: 64px;
  }

  .navbar__container {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .navbar__logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    min-width: max-content;
  }

  .navbar__logo-icon {
    width: 2rem;
    height: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--color-primary);
    color: var(--color-accent-sand);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .navbar__logo-text {
    display: flex;
    flex-direction: column;
  }

  .navbar__logo-main {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    color: var(--color-primary);
    line-height: 1;
    letter-spacing: 0.02em;
  }

  .navbar__logo-sub {
    margin-top: 0.14rem;
    color: var(--color-text-muted);
    font-size: 0.5rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .navbar__links {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .navbar__links a {
    position: relative;
    padding: 0.55rem 0;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    font-weight: 600;
  }

  .navbar__links a:hover,
  .navbar__links a.active {
    color: var(--color-primary);
  }

  .navbar__links a.active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 2px;
    background-color: var(--color-accent-warm);
  }

  .navbar__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .navbar__cta {
    padding: 0.5rem 1.15rem;
    border-radius: var(--radius-md);
    font-size: 0.85rem;
  }

  .lang-selector,
  .logout-btn {
    color: var(--color-text-secondary);
    font-size: 0.8rem;
    font-weight: 600;
  }

  .logout-btn {
    padding: 0.4rem 0;
    opacity: 0.72;
  }

  .logout-btn:hover {
    color: var(--color-primary);
    opacity: 1;
  }

  .navbar__mobile-toggle {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 24px;
    height: 18px;
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 201;
  }

  .navbar__mobile-toggle .bar {
    width: 100%;
    height: 2px;
    background-color: var(--color-primary);
    transition: transform var(--transition-base), opacity var(--transition-base);
  }

  .navbar__mobile-toggle.active .bar:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }

  .navbar__mobile-toggle.active .bar:nth-child(2) {
    opacity: 0;
  }

  .navbar__mobile-toggle.active .bar:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  .mobile-menu {
    position: fixed;
    top: var(--navbar-height);
    left: 0;
    width: 100%;
    height: calc(100vh - var(--navbar-height));
    background-color: var(--color-offwhite);
    transform: translateX(100%);
    transition: transform var(--transition-base);
    z-index: 200;
    overflow-y: auto;
  }

  .mobile-menu.active {
    transform: translateX(0);
  }

  .mobile-menu__inner {
    min-height: 100%;
    padding: 2rem;
    display: flex;
    flex-direction: column;
  }

  .mobile-menu__links {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .mobile-menu__links a {
    color: var(--color-text-primary);
    font-family: var(--font-heading);
    font-size: 1.45rem;
  }

  .mobile-menu__links a.active {
    color: var(--color-primary);
  }

  .mobile-menu__actions {
    margin-top: auto;
    padding-top: 2rem;
    display: grid;
    gap: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .mobile-menu__actions .btn {
    width: 100%;
  }

  .md-hidden {
    display: none;
  }

  @media (max-width: 1024px) {
    .hidden.md-flex {
      display: none !important;
    }

    .md-hidden {
      display: flex !important;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var navbar = document.getElementById('navbar');
    var mobileToggle = document.getElementById('mobileToggle');
    var mobileMenu = document.getElementById('mobileMenu');

    function updateNavbarShadow() {
      if (!navbar) return;
      navbar.classList.toggle('scrolled', window.scrollY > 20);
    }

    updateNavbarShadow();
    window.addEventListener('scroll', updateNavbarShadow, { passive: true });

    if (mobileToggle && mobileMenu) {
      mobileToggle.addEventListener('click', function () {
        var isOpen = mobileMenu.classList.toggle('active');
        mobileToggle.classList.toggle('active', isOpen);
        mobileToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        document.body.style.overflow = isOpen ? 'hidden' : '';
      });
    }

    function handleLogout() {
      localStorage.removeItem('indococopeat_access');
      window.location.href = '/access';
    }

    var logoutBtn = document.getElementById('logoutBtn');
    var mobileLogoutBtn = document.getElementById('mobileLogoutBtn');

    if (logoutBtn) logoutBtn.addEventListener('click', handleLogout);
    if (mobileLogoutBtn) mobileLogoutBtn.addEventListener('click', handleLogout);
  });
</script>
