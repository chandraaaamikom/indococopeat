---
export interface Props {
  currentPage?: string;
}

const { currentPage = '' } = Astro.props;
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';

const links = [
  { label: 'Home', href: '/', key: 'home' },
  { label: 'Products', href: '/products', key: 'products' },
  { label: 'Farm', href: '/farm', key: 'farm' },
  { label: 'Contact', href: '/contact', key: 'contact' },
];

const isActive = (href: string, key: string) =>
  currentPage === key || pathname === href;
---

<nav class="navbar" id="navbar">
  <div class="container navbar__container">
    <!-- Logo -->
   <a href="/" class="navbar__logo" aria-label="INDOCOCOPEAT home">
  <img
    src="/images/Indococopeat.png"
    alt="INDOCOCOPEAT Logo"
    class="navbar__logo-img"
  />

  <div class="navbar__logo-text">
    <span class="navbar__logo-main">
      <span class="navbar__logo-indo">INDO</span>
      <span class="navbar__logo-coco">COCOPEAT</span>
    </span>

    <span class="navbar__logo-sub">
      CV LOKA ADI JAYA
    </span>
  </div>
</a>
    <!-- Desktop Nav Links -->
    <ul class="navbar__links hidden md-flex">
      {links.map((link) => (
        <li>
          <a href={link.href} class={isActive(link.href, link.key) ? 'active' : ''}>{link.label}</a>
        </li>
      ))}
    </ul>

    <!-- Desktop Actions -->
    <div class="navbar__actions hidden md-flex">
      <a href="/contact" class="btn btn--accent navbar__cta">Get in Touch</a>
      <button id="logoutBtn" class="logout-btn" type="button">Exit Private View</button>
    </div>

    <!-- Mobile Toggle -->
    <button class="navbar__mobile-toggle md-hidden" id="mobileToggle" type="button" aria-label="Toggle menu" aria-expanded="false">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobileMenu">
    <div class="mobile-menu__inner">
      <ul class="mobile-menu__links">
        {links.map((link) => (
          <li>
            <a href={link.href} class={isActive(link.href, link.key) ? 'active' : ''}>{link.label}</a>
          </li>
        ))}
      </ul>
      <div class="mobile-menu__actions">
        <a href="/contact" class="btn btn--accent">Get in Touch</a>
        <button id="mobileLogoutBtn" class="btn btn--ghost" type="button">Logout Access</button>
      </div>
    </div>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: var(--navbar-height);
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-border);
    z-index: var(--z-sticky);
    transition: background-color var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
  }

  /* Transparent mode when hero is visible */
  .navbar.hero-mode {
    background-color: rgba(14, 32, 22, 0.15);
    border-bottom-color: rgba(255, 255, 255, 0.12);
  }

  .navbar.hero-mode .navbar__logo-main .navbar__logo-indo {
    color: #C8892A;
  }

  .navbar.hero-mode .navbar__logo-main .navbar__logo-coco {
    color: var(--color-white);
  }

  .navbar.hero-mode .navbar__logo-sub {
    color: rgba(255, 255, 255, 0.6);
  }

  .navbar.hero-mode .navbar__links a {
    color: rgba(255, 255, 255, 0.85);
  }

  .navbar.hero-mode .navbar__links a:hover,
  .navbar.hero-mode .navbar__links a.active {
    color: var(--color-white);
  }

  .navbar.hero-mode .logout-btn {
    color: rgba(255, 255, 255, 0.7);
  }

  .navbar.hero-mode .logout-btn:hover {
    color: var(--color-white);
  }

  .navbar.scrolled {
    background-color: rgba(255, 255, 255, 0.98);
    border-bottom-color: var(--color-border);
    box-shadow: 0 2px 20px rgba(26, 54, 38, 0.08);
  }

  .navbar__container {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  /* ---- LOGO ---- */
  .navbar__logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    min-width: max-content;
    flex-shrink: 0;
  }

  .navbar__logo-svg {
    width: 38px;
    height: 44px;
    flex-shrink: 0;
    transition: transform var(--transition-base);
  }

  .navbar__logo:hover .navbar__logo-svg {
    transform: scale(1.05);
  }

  .navbar__logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }

  .navbar__logo-main {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    line-height: 1;
    letter-spacing: 0.01em;
  }

  .navbar__logo-indo {
    color: var(--color-accent);
    transition: color var(--transition-base);
  }

  .navbar__logo-coco {
    color: var(--color-primary);
    transition: color var(--transition-base);
  }

  .navbar__logo-sub {
    margin-top: 0.2rem;
    color: var(--color-text-muted);
    font-size: 0.48rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-family: var(--font-body);
    font-weight: 600;
    transition: color var(--transition-base);
  }

  /* ---- NAV LINKS ---- */
  .navbar__links {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .navbar__links a {
    position: relative;
    padding: 0.5rem 0;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: color var(--transition-fast);
    letter-spacing: 0.01em;
  }

  .navbar__links a::after {
    content: '';
    position: absolute;
    left: 0;
    right: 100%;
    bottom: -2px;
    height: 2px;
    background: var(--color-accent);
    border-radius: var(--radius-full);
    transition: right var(--transition-base);
  }

  .navbar__links a:hover::after,
  .navbar__links a.active::after {
    right: 0;
  }

  .navbar__links a:hover,
  .navbar__links a.active {
    color: var(--color-primary);
  }

  /* ---- ACTIONS ---- */
  .navbar__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  .navbar__cta {
    padding: 0.55rem 1.25rem;
    font-size: 0.83rem;
  }

  .logout-btn {
    color: var(--color-text-secondary);
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.4rem 0;
    opacity: 0.72;
    transition: color var(--transition-fast), opacity var(--transition-fast);
    background: none;
    border: none;
    cursor: pointer;
  }

  .logout-btn:hover {
    color: var(--color-primary);
    opacity: 1;
  }

  /* ---- MOBILE TOGGLE ---- */
  .navbar__mobile-toggle {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 24px;
    height: 18px;
    background: transparent;
    border: none;
    cursor: pointer;
    z-index: 201;
  }

  .navbar__mobile-toggle .bar {
    width: 100%;
    height: 2px;
    background-color: var(--color-primary);
    border-radius: var(--radius-full);
    transition: transform var(--transition-base), opacity var(--transition-base);
  }

  .navbar.hero-mode .navbar__mobile-toggle .bar {
    background-color: var(--color-white);
  }

  .navbar__mobile-toggle.active .bar:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }

  .navbar__mobile-toggle.active .bar:nth-child(2) {
    opacity: 0;
  }

  .navbar__mobile-toggle.active .bar:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  /* ---- MOBILE MENU ---- */
  .mobile-menu {
    position: fixed;
    top: var(--navbar-height);
    left: 0;
    width: 100%;
    height: calc(100vh - var(--navbar-height));
    background-color: var(--color-white);
    transform: translateX(100%);
    transition: transform var(--transition-base);
    z-index: 200;
    overflow-y: auto;
    border-top: 1px solid var(--color-border);
  }

  .mobile-menu.active {
    transform: translateX(0);
  }

  .mobile-menu__inner {
    min-height: 100%;
    padding: 2rem;
    display: flex;
    flex-direction: column;
  }

  .mobile-menu__links {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .mobile-menu__links li {
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-menu__links a {
    display: block;
    padding: 1.1rem 0;
    color: var(--color-text-primary);
    font-family: var(--font-heading);
    font-size: 1.5rem;
    text-decoration: none;
    transition: color var(--transition-fast), padding var(--transition-fast);
  }

  .mobile-menu__links a.active,
  .mobile-menu__links a:hover {
    color: var(--color-accent);
    padding-left: 0.5rem;
  }

  .mobile-menu__actions {
    margin-top: 2.5rem;
    display: grid;
    gap: 1rem;
  }

  .mobile-menu__actions .btn {
    width: 100%;
  }

  /* ---- Responsive ---- */
  .md-hidden {
    display: none;
  }

  @media (max-width: 1024px) {
    .hidden.md-flex {
      display: none !important;
    }

    .md-hidden {
      display: flex !important;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var navbar = document.getElementById('navbar');
    var mobileToggle = document.getElementById('mobileToggle');
    var mobileMenu = document.getElementById('mobileMenu');

    // Detect if page has a full-bleed hero
    var heroEl = document.querySelector('.home-hero-fullbleed');

    function updateNavbar() {
      if (!navbar) return;
      var scrolled = window.scrollY > 20;
      navbar.classList.toggle('scrolled', scrolled);

      if (heroEl) {
        var heroBottom = heroEl.getBoundingClientRect().bottom;
        var isOverHero = heroBottom > 0 && !scrolled;
        navbar.classList.toggle('hero-mode', isOverHero);
      }
    }

    updateNavbar();
    window.addEventListener('scroll', updateNavbar, { passive: true });

    if (mobileToggle && mobileMenu) {
      mobileToggle.addEventListener('click', function () {
        var isOpen = mobileMenu.classList.toggle('active');
        mobileToggle.classList.toggle('active', isOpen);
        mobileToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        document.body.style.overflow = isOpen ? 'hidden' : '';
      });
    }

    function handleLogout() {
      localStorage.removeItem('indococopeat_access');
      window.location.href = '/access';
    }

    var logoutBtn = document.getElementById('logoutBtn');
    var mobileLogoutBtn = document.getElementById('mobileLogoutBtn');

    if (logoutBtn) logoutBtn.addEventListener('click', handleLogout);
    if (mobileLogoutBtn) mobileLogoutBtn.addEventListener('click', handleLogout);
  });
</script>
