---
import { company } from '../data/company';
import { socialLinks } from '../data/social';

const quickLinks = [
  { label: 'Home', href: '/home' },
  { label: 'Products', href: '/product' },
  { label: 'Our Farms', href: '/farm' },
  { label: 'Contact Us', href: '/contact' },
];

const addressLine = `${company.address.street}, ${company.address.province}\nIndonesia ${company.address.postalCode}`;
---

<footer class="site-footer" role="contentinfo">
  <div class="footer-top">
    <div class="footer-container">
      <div class="footer-grid">
        <!-- Column 1: About -->
        <div class="footer-col footer-col--about">
          <a href="/" class="footer-logo" aria-label="INDOCOCOPEAT — Home">
            <span class="footer-logo__indo">INDOCO</span><span class="footer-logo__peat">PEAT</span>
          </a>
          <p class="footer-tagline">PURE FIBER, GLOBAL GROWTH</p>
          <p class="footer-description">{company.shortDescription}</p>
        </div>

        <!-- Column 2: Quick Links -->
        <div class="footer-col footer-col--links">
          <h3 class="footer-heading">Quick Links</h3>
          <nav aria-label="Footer navigation">
            <ul class="footer-links" role="list">
              {quickLinks.map((link) => (
                <li>
                  <a href={link.href} class="footer-link">{link.label}</a>
                </li>
              ))}
            </ul>
          </nav>
        </div>

        <!-- Column 3: Contact -->
        <div class="footer-col footer-col--contact">
          <h3 class="footer-heading">Contact</h3>
          <address class="footer-address">
            <div class="footer-contact-item">
              <span class="footer-contact-icon" aria-hidden="true">📍</span>
              <span class="footer-contact-text">
                {company.address.street}, {company.address.province}<br />
                Indonesia {company.address.postalCode}
              </span>
            </div>
            <div class="footer-contact-item">
              <span class="footer-contact-icon" aria-hidden="true">📞</span>
              <a href={`tel:+${company.whatsappNumber}`} class="footer-contact-link">{company.hotline}</a>
            </div>
            <div class="footer-contact-item">
              <span class="footer-contact-icon" aria-hidden="true">✉️</span>
              <a href={`mailto:${company.email}`} class="footer-contact-link">{company.email}</a>
            </div>
          </address>

          <div class="footer-social">
            {socialLinks.map((social) => (
              <a
                href={social.url}
                class="footer-social-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Follow us on ${social.name}`}
              >
                <span aria-hidden="true">{social.icon}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="footer-container">
      <div class="footer-bottom-inner">
        <p class="footer-copyright">&copy; 2024 INDOCOCOPEAT. All rights reserved.</p>
        <p class="footer-legal-name">PT. Abbasy Jaya Makmur</p>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    width: 100%;
    overflow: hidden;
  }

  /* ===== Top Section ===== */
  .footer-top {
    background-color: #1b4332;
    padding: 5rem 0 3rem;
  }

  .footer-container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }

  /* ===== Column: About ===== */
  .footer-col--about {
    text-align: center;
  }

  .footer-logo {
    display: inline-block;
    font-family: 'DM Serif Display', serif;
    font-size: 1.5rem;
    line-height: 1;
    text-decoration: none;
    letter-spacing: 0.02em;
  }

  .footer-logo__indo {
    color: #ffffff;
  }

  .footer-logo__peat {
    color: #d4a574;
  }

  .footer-tagline {
    font-family: 'Inter', sans-serif;
    font-size: 0.625rem;
    font-variant: small-caps;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.5);
    margin-top: 0.5rem;
    margin-bottom: 0;
  }

  .footer-description {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    max-width: 280px;
    margin: 1rem auto 0;
  }

  /* ===== Column Headings ===== */
  .footer-heading {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #ffffff;
    margin: 0 0 1.25rem;
  }

  /* ===== Column: Quick Links ===== */
  .footer-col--links {
    text-align: center;
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-links li {
    margin: 0;
    padding: 0;
  }

  .footer-link {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    padding: 0.375rem 0;
    transition: color 0.25s ease, transform 0.25s ease;
  }

  .footer-link:hover,
  .footer-link:focus-visible {
    color: #ffffff;
    transform: translateX(3px);
  }

  .footer-link:focus-visible {
    outline: 2px solid #d4a574;
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* ===== Column: Contact ===== */
  .footer-col--contact {
    text-align: center;
  }

  .footer-address {
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-contact-item {
    display: flex;
    align-items: flex-start;
    gap: 0.625rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.6;
    justify-content: center;
  }

  .footer-contact-icon {
    flex-shrink: 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .footer-contact-text {
    text-align: left;
  }

  .footer-contact-link {
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.65);
    text-decoration: none;
    transition: color 0.25s ease;
  }

  .footer-contact-link:hover,
  .footer-contact-link:focus-visible {
    color: #ffffff;
  }

  .footer-contact-link:focus-visible {
    outline: 2px solid #d4a574;
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* ===== Social Links ===== */
  .footer-social {
    display: flex;
    gap: 0.625rem;
    margin-top: 1.5rem;
    justify-content: center;
  }

  .footer-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.1);
    text-decoration: none;
    font-size: 0.875rem;
    transition: background-color 0.25s ease, transform 0.2s ease;
  }

  .footer-social-link:hover,
  .footer-social-link:focus-visible {
    background-color: rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }

  .footer-social-link:focus-visible {
    outline: 2px solid #d4a574;
    outline-offset: 2px;
  }

  /* ===== Bottom Bar ===== */
  .footer-bottom {
    background-color: #152e22;
    padding: 1.25rem 0;
  }

  .footer-bottom-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
  }

  .footer-copyright,
  .footer-legal-name {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.4);
    margin: 0;
    line-height: 1.5;
  }

  /* ===== Tablet: 768px+ ===== */
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }

    .footer-col--about {
      grid-column: 1 / -1;
      text-align: left;
    }

    .footer-description {
      margin-left: 0;
    }

    .footer-col--links {
      text-align: left;
    }

    .footer-link:hover,
    .footer-link:focus-visible {
      transform: translateX(3px);
    }

    .footer-col--contact {
      text-align: left;
    }

    .footer-contact-item {
      justify-content: flex-start;
    }

    .footer-social {
      justify-content: flex-start;
    }

    .footer-bottom-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  /* ===== Desktop: 1024px+ ===== */
  @media (min-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1.4fr 0.8fr 1fr;
      gap: 4rem;
    }

    .footer-col--about {
      grid-column: auto;
    }

    .footer-top {
      padding: 5rem 0 3rem;
    }
  }
</style>
