---
import MainLayout from '../layouts/MainLayout.astro';
import { company, statistics, whyChooseUs, businessProcess } from '../data/company';

const previewCards = whyChooseUs.slice(0, 3);
const processPreview = businessProcess.slice(0, 4);
---

<MainLayout
  title="INDOCOCOPEAT - Premium Cocopeat Exporter from Indonesia"
  description="INDOCOCOPEAT supplies premium cocopeat and coconut fiber products from Indonesia for global agriculture, horticulture, and export buyers."
  currentPage="home"
>
  <main class="page-content site-texture home-page">
    <section class="home-hero">
      <div class="container home-hero__grid">
        <div class="home-hero__copy">
          <span class="section-label">Premium export</span>
          <h1>Pure fiber, global growth</h1>
          <p>
            Premium cocopeat and coconut fiber from Indonesia, processed for reliable global supply and sustainable growing media.
          </p>
          <div class="home-hero__actions">
            <a href="/products" class="btn btn--primary btn--lg">Explore Products</a>
            <a href="/contact" class="btn btn--secondary btn--lg">Request Catalog</a>
          </div>
        </div>
        <div class="home-hero__visual" aria-label="Coconut fiber product texture">
          <img src="/images/hero/bg-fiber.webp" alt="Processed coconut fiber prepared for export" />
        </div>
      </div>
    </section>

    <section class="home-stats" aria-label="Company statistics">
      <div class="container home-stats__grid">
        {statistics.map((stat) => (
          <article class="home-stat">
            <strong>{stat.value}{stat.suffix}</strong>
            <span>{stat.label}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="section home-overview">
      <div class="container home-overview__grid">
        <div>
          <span class="section-label">About INDOCOCOPEAT</span>
          <h2>{company.legalName}</h2>
        </div>
        <p>{company.shortDescription}</p>
      </div>
    </section>

    <section class="section section--white">
      <div class="container">
        <div class="section-header reveal">
          <h2 class="section-title">Quality, supply, and sustainability</h2>
          <p class="section-subtitle">A focused overview of what buyers can expect from our export process.</p>
        </div>

        <div class="grid grid--3 reveal">
          {previewCards.map((item) => (
            <article class="card home-card">
              <div class="home-card__icon" aria-hidden="true">{item.icon}</div>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section home-process">
      <div class="container">
        <div class="section-header reveal">
          <h2 class="section-title">From regional supply to export packing</h2>
        </div>

        <div class="home-process__grid reveal">
          {processPreview.map((step) => (
            <article>
              <span>{step.step}</span>
              <h3>{step.title}</h3>
              <p>{step.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="home-cta">
      <div class="container">
        <div class="home-cta__panel reveal">
          <h2>Ready to source premium cocopeat?</h2>
          <p>Explore the product catalog or request export information from our team.</p>
          <div>
            <a href="/products" class="btn">View Products</a>
            <a href="/contact" class="btn btn--ghost">Contact Us</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <style>
    .home-page {
      min-height: 100vh;
    }

    .home-hero {
      padding: 6rem 0 4rem;
    }

    .home-hero__grid {
      display: grid;
      grid-template-columns: minmax(0, 0.95fr) minmax(320px, 1.05fr);
      gap: clamp(2rem, 5vw, 5rem);
      align-items: center;
    }

    .home-hero__copy h1 {
      margin: 0 0 1.25rem;
      color: var(--color-primary);
      font-size: clamp(3.3rem, 6vw, 6rem);
      line-height: 0.96;
      text-wrap: balance;
    }

    .home-hero__copy p {
      max-width: 590px;
      margin-bottom: 2rem;
      font-size: 1.1rem;
    }

    .home-hero__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .home-hero__visual {
      position: relative;
      min-height: 530px;
      overflow: hidden;
      border-radius: 120px 20px 120px 20px;
      box-shadow: 0 28px 70px rgba(var(--color-primary-rgb), 0.2);
    }

    .home-hero__visual::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(26, 54, 38, 0.16), rgba(139, 90, 43, 0.36));
    }

    .home-hero__visual img {
      width: 100%;
      height: 100%;
      min-height: 530px;
      object-fit: cover;
    }

    .home-stats {
      margin-top: -1rem;
      padding-bottom: 3rem;
    }

    .home-stats__grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1rem;
    }

    .home-stat {
      padding: 1.4rem;
      border-radius: var(--radius-xl);
      background: var(--color-primary);
      color: var(--color-white);
      box-shadow: var(--shadow-md);
    }

    .home-stat strong {
      display: block;
      color: var(--color-accent-warm);
      font-family: var(--font-heading);
      font-size: 2.2rem;
      line-height: 1;
    }

    .home-stat span {
      display: block;
      margin-top: 0.55rem;
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .home-overview__grid {
      display: grid;
      grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
      gap: 2rem;
      align-items: start;
    }

    .home-overview h2,
    .home-cta h2 {
      color: var(--color-primary);
      font-size: clamp(2rem, 4vw, 3.2rem);
    }

    .home-overview p {
      max-width: 720px;
      font-size: 1.05rem;
    }

    .home-card {
      height: 100%;
      padding: 2rem;
      border: 1px solid var(--color-border);
      box-shadow: none;
    }

    .home-card__icon {
      margin-bottom: 1.25rem;
      color: var(--color-primary);
      font-size: 1.7rem;
    }

    .home-card h3 {
      margin-bottom: 0.75rem;
      color: var(--color-primary);
      font-size: 1.35rem;
    }

    .home-process {
      background: rgba(244, 239, 230, 0.5);
    }

    .home-process__grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1rem;
    }

    .home-process__grid article {
      padding: 1.5rem;
      border-radius: var(--radius-lg);
      background: var(--color-white);
      border: 1px solid var(--color-border);
    }

    .home-process__grid span {
      display: inline-flex;
      width: 2rem;
      height: 2rem;
      align-items: center;
      justify-content: center;
      margin-bottom: 1rem;
      border-radius: 50%;
      background: var(--color-light-gray);
      color: var(--color-primary);
      font-weight: 800;
    }

    .home-process__grid h3 {
      margin-bottom: 0.5rem;
      color: var(--color-primary);
      font-size: 1.1rem;
    }

    .home-process__grid p {
      font-size: 0.9rem;
    }

    .home-cta {
      padding: 5rem 0;
    }

    .home-cta__panel {
      padding: clamp(2.5rem, 5vw, 4rem);
      border-radius: var(--radius-2xl);
      background:
        linear-gradient(135deg, rgba(26, 54, 38, 0.96), rgba(42, 75, 58, 0.96)),
        var(--color-primary);
      color: var(--color-white);
      text-align: center;
    }

    .home-cta__panel h2 {
      color: var(--color-white);
      margin-bottom: 1rem;
    }

    .home-cta__panel p {
      max-width: 560px;
      margin: 0 auto 2rem;
      color: rgba(255, 255, 255, 0.82);
    }

    .home-cta__panel > div {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 1rem;
    }

    .home-cta__panel .btn:first-child {
      background: var(--color-accent-warm);
      color: var(--color-primary-dark);
    }

    .home-cta__panel .btn--ghost {
      color: var(--color-white);
      border-color: rgba(255, 255, 255, 0.46);
    }

    @media (max-width: 900px) {
      .home-hero__grid,
      .home-overview__grid {
        grid-template-columns: 1fr;
      }

      .home-hero__visual {
        min-height: 320px;
        border-radius: var(--radius-2xl);
      }

      .home-hero__visual img {
        min-height: 320px;
      }

      .home-stats__grid,
      .home-process__grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 560px) {
      .home-hero {
        padding-top: 4rem;
      }

      .home-stats__grid,
      .home-process__grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</MainLayout>
