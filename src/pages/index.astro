---
import MainLayout from '../layouts/MainLayout.astro';
import { company, statistics, whyChooseUs, businessProcess } from '../data/company';

const previewCards = whyChooseUs.slice(0, 3);
const processPreview = businessProcess.slice(0, 4);
const whatsappUrl = `https://wa.me/${company.whatsappNumber}?text=${encodeURIComponent('Hello INDOCOCOPEAT, I would like to request product catalog and export quotation.')}`;

const iconMap: Record<string, string> = {
  Natural: '🌿',
  Supply: '🔗',
  Quality: '✅',
  Process: '⚙️',
  Global: '🌏',
  Partner: '🤝',
};
---

<MainLayout
  title="INDOCOCOPEAT - Premium Cocopeat Exporter from Indonesia"
  description="INDOCOCOPEAT supplies premium cocopeat and coconut fiber products from Indonesia for global agriculture, horticulture, and export buyers."
  currentPage="home"
>
  <main class="home-page">

    <!-- ======================================================
         HERO SECTION (Agroton Premium Style)
    ====================================================== -->
    <section class="premium-hero" aria-label="Hero section">
      <div class="container hero-container">
        
        <!-- Hero Header -->
        <div class="hero-top-grid">
          <div class="hero-top-left">
            <span class="badge badge--dark hero-badge">✦ Premium Cocopeat Export</span>
            <h1 class="hero-main-title">
              INDOCOCOPEAT one of the largest <span class="highlight-text">producers of agricultural</span> cocopeat in Indonesia
            </h1>
            <p class="hero-subtext-para">
              PT. Abbasy Jaya Makmur is an export-ready processing company. We are engaged in the cultivation of green coconut fiber materials, processing premium cocopeat products and supplying agricultural materials globally.
            </p>
            <div class="hero-actions-row">
              <a href="/products" class="btn-dark-pill">
                Explore Products
                <span class="pill-arrow">→</span>
              </a>
              <a href="/contact" class="btn-clean-link">
                Request Catalog
              </a>
            </div>
          </div>
        </div>

        <!-- Hero Media and Stats Grid -->
        <div class="hero-interactive-grid">
          <!-- Main Hero Image -->
          <div class="hero-main-image-card">
            <img src="/images/hero/bg-fiber.webp" alt="Coconut fiber fields in Indonesia" />
            <div class="card-overlay"></div>
          </div>

          <!-- Small Stat Cards Row -->
          <div class="hero-stats-subgrid">
            <div class="hero-stat-card">
              <strong class="stat-big-num">100%</strong>
              <span class="stat-card-title">Export Grade</span>
              <p class="stat-card-desc">Prepared strictly to match international buyers' requirements.</p>
            </div>
            
            <div class="hero-stat-card">
              <strong class="stat-big-num">500+</strong>
              <span class="stat-card-title">Tons Monthly</span>
              <p class="stat-card-desc">High-volume processing capacity to handle large contract orders.</p>
            </div>

            <div class="hero-stat-card">
              <strong class="stat-big-num">12+</strong>
              <span class="stat-card-title">Export Ports</span>
              <p class="stat-card-desc">Strategic shipments reaching global growers & horticulturalists.</p>
            </div>

            <!-- Dark Leader Card -->
            <div class="hero-dark-info-card">
              <div class="info-card-header">
                <span class="info-label">Leader</span>
                <a href="/farm" class="info-circle-btn">→</a>
              </div>
              <h3 class="info-card-title">INDOCOCOPEAT is among the leaders in coconut coir supply in Central Java.</h3>
              <p class="info-card-text">We connect sustainable regional farming networks with automated high-pressure processing facilities.</p>
              <img src="/images/farms/kebun.jpg" alt="Farming networks" class="info-card-thumbnail" />
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ======================================================
         ABOUT SECTION
    ====================================================== -->
    <section class="section premium-about-section" aria-label="About INDOCOCOPEAT">
      <div class="container">
        
        <div class="about-top-kicker">
          <span class="section-badge-kicker">✦ About us</span>
        </div>

        <div class="about-split-grid">
          <div class="about-grid-left">
            <h2 class="about-heading-main">
              Our development path: from regional collection to global leadership
            </h2>
            <div class="about-mini-image">
              <img src="/images/farms/kebun.jpg" alt="Local farm sourcing" />
            </div>
          </div>

          <div class="about-grid-right">
            <div class="about-paragraphs">
              <p class="paragraph-highlight">
                Founded with a vision to upgrade Indonesia's natural coconut husks, CV LOKA ADI JAYA now coordinates with over 200 partner farmers. Thanks to stable development and investment in modern processing technologies, we maintain quality standards across every production batch.
              </p>
              <p class="paragraph-regular">
                Today, INDOCOCOPEAT cultivates regional collection routes, houses large storage capacities, and is one of the leading producers of agricultural cocopeat block, coir fiber, and peat products in Indonesia. We actively supply buyers in the Americas, Europe, and Asia.
              </p>
            </div>
            <div class="about-mini-image-two">
              <img src="/images/hero/bg-fiber.webp" alt="Processed coconut fiber" />
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ======================================================
         DASHBOARD BLOCK (Dark Forest Green Panel)
    ====================================================== -->
    <section class="section dark-dashboard-section" aria-label="Operations and statistics">
      <div class="container">
        
        <div class="dashboard-shell-grid">
          <!-- Left side: Map & Stats -->
          <div class="dashboard-left-panel">
            <h3 class="panel-heading">Our supply path: from local collection points to export</h3>
            
            <!-- Map Visualization Card -->
            <div class="map-graphic-box">
              <div class="map-decor-svg">
                <svg viewBox="0 0 800 400" fill="none" class="world-map-svg">
                  <!-- Simple dotted map placeholder style -->
                  <rect width="800" height="400" fill="none" />
                  <path d="M150,220 Q240,150 350,180 T600,200" stroke="rgba(200, 137, 42, 0.4)" stroke-dasharray="5 5" stroke-width="2" />
                  <circle cx="150" cy="220" r="8" fill="#C8892A" />
                  <circle cx="350" cy="180" r="6" fill="#C8892A" />
                  <circle cx="600" cy="200" r="10" fill="#C8892A" />
                  <text x="170" y="225" fill="white" font-size="12" font-weight="600">Central Java Sourcing</text>
                  <text x="620" y="205" fill="white" font-size="12" font-weight="600">Global Buyers</text>
                </svg>
              </div>
            </div>

            <!-- Stats Bar -->
            <div class="dashboard-stats-strip">
              <div class="dash-stat">
                <span class="dash-stat-num">200+</span>
                <span class="dash-stat-lbl">Farmers Network</span>
              </div>
              <div class="dash-stat">
                <span class="dash-stat-num">500 Tons</span>
                <span class="dash-stat-lbl">Monthly Capacity</span>
              </div>
              <div class="dash-stat">
                <span class="dash-stat-num">12+</span>
                <span class="dash-stat-lbl">Countries Reached</span>
              </div>
            </div>
          </div>

          <!-- Right side: Specs distribution chart style -->
          <div class="dashboard-right-panel">
            <div class="dashboard-chart-card">
              <h4 class="chart-title">Quality Parameter Control</h4>
              <p class="chart-subtitle">Standard specifications maintained during sorting & packing</p>
              
              <!-- Quality Parameter Bars -->
              <div class="chart-bars-list">
                <div class="chart-bar-row">
                  <div class="bar-info">
                    <span>Low EC (< 0.5 mS/cm)</span>
                    <strong>85%</strong>
                  </div>
                  <div class="bar-line-bg"><div class="bar-line-fill" style="width: 85%;"></div></div>
                </div>
                
                <div class="chart-bar-row">
                  <div class="bar-info">
                    <span>Optimal Moisture (15-20%)</span>
                    <strong>90%</strong>
                  </div>
                  <div class="bar-line-bg"><div class="bar-line-fill" style="width: 90%;"></div></div>
                </div>

                <div class="chart-bar-row">
                  <div class="bar-info">
                    <span>Peat/Fiber Ratio Control</span>
                    <strong>95%</strong>
                  </div>
                  <div class="bar-line-bg"><div class="bar-line-fill" style="width: 95%;"></div></div>
                </div>
              </div>

              <!-- Mini CTA box inside dashboard -->
              <div class="dashboard-join-card">
                <div class="join-info">
                  <h5>Join Our Global Buyers Network</h5>
                  <p>Request export prices, packaging options, and container schedules.</p>
                </div>
                <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="join-action-btn">
                  Connect Now
                  <span class="btn-arrow">→</span>
                </a>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ======================================================
         WHY CHOOSE US (Agroton Card Layout)
    ====================================================== -->
    <section class="section premium-why-section" aria-label="Why choose INDOCOCOPEAT">
      <div class="container">
        
        <div class="why-header-grid">
          <div class="why-header-left">
            <span class="section-badge-kicker">✦ Our Strengths</span>
            <h2 class="why-heading-title">We ensure premium quality and stable global supplies</h2>
          </div>
        </div>

        <div class="premium-why-cards-grid">
          {whyChooseUs.map((item, i) => (
            <article class="why-item-card">
              <div class="why-item-top">
                <span class="why-item-num">0{i + 1}</span>
              </div>
              <h3 class="why-item-title">{item.title}</h3>
              <p class="why-item-desc">{item.description}</p>
            </article>
          ))}
        </div>

      </div>
    </section>

    <!-- ======================================================
         PROCESS PATHWAY SECTION
    ====================================================== -->
    <section class="section premium-process-section" aria-label="Production workflow">
      <div class="container">
        
        <div class="process-section-header">
          <span class="section-badge-kicker">✦ Workflow</span>
          <h2 class="process-title-main">We process agricultural cocopeat with modern standards and respect for nature</h2>
        </div>

        <!-- Horizontal/Grid process pathway -->
        <div class="premium-process-grid">
          {businessProcess.map((step) => (
            <div class="premium-process-card">
              <div class="proc-icon-row">
                <span class="proc-step-num">0{step.step}</span>
                <span class="proc-bullet-dot"></span>
              </div>
              <h3 class="proc-card-title">{step.title}</h3>
              <p class="proc-card-desc">{step.description}</p>
            </div>
          ))}
        </div>

        <!-- Sourcing Action Bar -->
        <div class="process-bottom-sourcing-bar">
          <div class="sourcing-text-side">
            <p>Our values align with <strong>sustainable development</strong>, <strong>direct supply chain</strong>, and <strong>certified quality</strong>.</p>
          </div>
          <div class="sourcing-btn-side">
            <a href="/products" class="btn-dark-pill">View Products →</a>
          </div>
        </div>

      </div>
    </section>

    <!-- ======================================================
         CTA SECTION (Clean Rounded Banner)
    ====================================================== -->
    <section class="premium-cta-banner-section" aria-label="Contact call to action">
      <div class="container">
        <div class="premium-cta-banner">
          <span class="cta-kicker">✦ Start sourcing</span>
          <h2 class="cta-banner-title">Ready to source premium Indonesian cocopeat?</h2>
          <p class="cta-banner-desc">Get in touch with PT. Abbasy Jaya Makmur today for custom packing, container loading parameters, and competitive FOB/CIF quotation.</p>
          <div class="cta-actions-row">
            <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn-accent-pill">
              Chat on WhatsApp
              <span class="arrow">→</span>
            </a>
            <a href="/contact" class="btn-outline-pill">
              Send Inquiry
            </a>
          </div>
        </div>
      </div>
    </section>

  </main>
</MainLayout>

<style>
  /* Premium Agroton-Inspired Layout Styles */

  .premium-hero {
    padding-top: calc(var(--navbar-height) + 3rem);
    padding-bottom: 5rem;
    background-color: var(--color-offwhite);
  }

  .hero-main-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 5vw, 4.2rem);
    color: var(--color-primary);
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }

  .highlight-text {
    font-weight: 300;
    font-style: italic;
    color: var(--color-text-secondary);
  }

  .hero-subtext-para {
    font-size: 1.05rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    max-width: 680px;
    margin-bottom: 2rem;
  }

  .hero-actions-row {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    margin-bottom: 3rem;
  }

  .btn-dark-pill {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 2rem;
    background-color: var(--color-primary);
    color: var(--color-white);
    border-radius: var(--radius-full);
    font-weight: 600;
    font-size: 0.95rem;
    transition: background-color var(--transition-base), transform var(--transition-base);
  }

  .btn-dark-pill:hover {
    background-color: var(--color-primary-dark);
    transform: translateY(-2px);
    color: var(--color-white);
  }

  .pill-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.8rem;
    height: 1.8rem;
    background: rgba(255,255,255,0.15);
    border-radius: 50%;
    font-size: 0.85rem;
  }

  .btn-clean-link {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-primary);
    border-bottom: 1.5px solid var(--color-primary);
    padding-bottom: 0.2rem;
    transition: opacity var(--transition-fast);
  }

  .btn-clean-link:hover {
    opacity: 0.8;
  }

  /* Interactive Image & Stats Grid */
  .hero-interactive-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 2rem;
    align-items: stretch;
  }

  .hero-main-image-card {
    position: relative;
    border-radius: 32px;
    overflow: hidden;
    min-height: 480px;
    box-shadow: var(--shadow-md);
  }

  .hero-main-image-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent, rgba(0,0,0,0.15));
    pointer-events: none;
  }

  .hero-stats-subgrid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .hero-stat-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 24px;
    padding: 1.75rem 2rem;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .hero-stat-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }

  .stat-big-num {
    display: block;
    font-size: 2.8rem;
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .stat-card-title {
    display: block;
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.35rem;
  }

  .stat-card-desc {
    font-size: 0.88rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* Dark Info Card */
  .hero-dark-info-card {
    background-color: var(--color-primary);
    color: var(--color-white);
    border-radius: 24px;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  .info-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .info-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-accent-warm);
  }

  .info-circle-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    background: rgba(255,255,255,0.1);
    color: white;
    border-radius: 50%;
    font-size: 1rem;
    transition: background var(--transition-fast);
  }

  .info-circle-btn:hover {
    background: rgba(255,255,255,0.25);
    color: white;
  }

  .info-card-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-white);
    line-height: 1.4;
    margin-bottom: 0.75rem;
  }

  .info-card-text {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .info-card-thumbnail {
    width: 100%;
    height: 120px;
    object-fit: cover;
    border-radius: 16px;
    margin-top: auto;
  }

  /* About Us split layout */
  .premium-about-section {
    background-color: var(--color-white);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .section-badge-kicker {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .about-split-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 4rem;
  }

  .about-heading-main {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3.5vw, 3rem);
    color: var(--color-primary);
    line-height: 1.15;
    margin-bottom: 3rem;
  }

  .about-mini-image {
    border-radius: 24px;
    overflow: hidden;
    height: 240px;
  }

  .about-mini-image img,
  .about-mini-image-two img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-paragraphs {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .paragraph-highlight {
    font-size: 1.1rem;
    color: var(--color-text-primary);
    line-height: 1.7;
    font-weight: 500;
  }

  .paragraph-regular {
    font-size: 0.98rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
  }

  .about-mini-image-two {
    border-radius: 24px;
    overflow: hidden;
    height: 180px;
  }

  /* Dashboard Block */
  .dark-dashboard-section {
    background-color: var(--color-primary);
    color: var(--color-white);
    border-radius: 32px;
    margin: 2rem var(--space-6);
    padding: var(--space-20) var(--space-10);
  }

  .dashboard-shell-grid {
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: 3.5rem;
    align-items: center;
  }

  .panel-heading {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    color: var(--color-white);
    line-height: 1.2;
    margin-bottom: 2rem;
  }

  .map-graphic-box {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 24px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .world-map-svg {
    width: 100%;
    height: auto;
  }

  .dashboard-stats-strip {
    display: flex;
    justify-content: space-between;
    gap: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 2rem;
  }

  .dash-stat {
    display: flex;
    flex-direction: column;
  }

  .dash-stat-num {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-accent-warm);
    line-height: 1.1;
  }

  .dash-stat-lbl {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.65);
    margin-top: 0.25rem;
  }

  /* Right Chart Card */
  .dashboard-chart-card {
    background: var(--color-white);
    border-radius: 24px;
    padding: 2.5rem;
    color: var(--color-text-primary);
  }

  .chart-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }

  .chart-subtitle {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
  }

  .chart-bars-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .chart-bar-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .bar-info {
    display: flex;
    justify-content: space-between;
    font-size: 0.88rem;
    font-weight: 600;
  }

  .bar-info span {
    color: var(--color-text-secondary);
  }

  .bar-info strong {
    color: var(--color-primary);
  }

  .bar-line-bg {
    height: 8px;
    background-color: var(--color-light-gray);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .bar-line-fill {
    height: 100%;
    background-color: var(--color-accent);
    border-radius: var(--radius-full);
  }

  .dashboard-join-card {
    background-color: var(--color-offwhite);
    border-radius: 16px;
    padding: 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
  }

  .dashboard-join-card h5 {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }

  .dashboard-join-card p {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    line-height: 1.4;
    margin: 0;
  }

  .join-action-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: var(--color-primary);
    color: white;
    padding: 0.75rem 1.25rem;
    border-radius: var(--radius-full);
    font-size: 0.85rem;
    font-weight: 600;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }

  .join-action-btn:hover {
    color: white;
    opacity: 0.9;
  }

  /* Why Choose Us Cards */
  .why-heading-title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3.5vw, 2.8rem);
    color: var(--color-primary);
    line-height: 1.15;
    margin-bottom: 3rem;
    max-width: 680px;
  }

  .premium-why-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .why-item-card {
    background: var(--color-white);
    border: 1px solid var(--color-border);
    border-radius: 24px;
    padding: 2.25rem 2rem;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .why-item-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }

  .why-item-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
