---
import MainLayout from '../layouts/MainLayout.astro';
import { company, whyChooseUs, businessProcess } from '../data/company';

const whatsappUrl = `https://wa.me/${company.whatsappNumber}?text=${encodeURIComponent('Hello INDOCOCOPEAT, I would like to request product catalog and export quotation.')}`;
---

<MainLayout
  title="INDOCOCOPEAT - SUSTAINABLE COCOPEAT SUPPLIER"
  description="INDOCOCOPEAT supplies premium cocopeat and coconut fiber products from Indonesia for global agriculture, horticulture, and export buyers."
  currentPage="home"
>
  <main class="home-page">

    <!-- ======================================================
         HERO SECTION
    ====================================================== -->
    <section class="premium-hero" aria-label="Hero section">
      <div class="container hero-container">
        
        <!-- Hero Header -->
        <div class="hero-top-grid">
          <div class="hero-top-left">
            <span class="badge badge--dark hero-badge">PREMIUM COCOPEAT & COCONUT FIBER EXPORT</span>

            <h1 class="hero-main-title">
              INDOCOCOPEAT Sustainable Cocopeat
              <span class="highlight-text">Coconut Fiber Products</span>
              from INDONESIA
            </h1>

            <p class="hero-subtext-para">
              CV LOKA ADI JAYA is an Indonesian cocopeat and coconut fiber supplier. We process coconut husks into sustainable growing media and natural fiber products for agriculture, horticulture, hydroponic systems, and industrial applications.
            </p>

            <div class="hero-actions-row">
              <a href="/products" class="btn-dark-pill">
                Explore Products
              </a>
              <a href="/contact" class="btn-clean-link">
                Request Catalog
              </a>
            </div>
          </div>
        </div>

        <!-- Hero Information Cards -->
        <div class="hero-interactive-grid">
          <div class="hero-stats-subgrid">
            <div class="hero-stat-card">
              <strong class="stat-big-num">22.5 Tons</strong>
              <span class="stat-card-title">Polybag Load Ability</span>
              <p class="stat-card-desc">
                Cocopeat Polybag can be loaded up to 22.5 tons in a 40 feet HC container.
              </p>
            </div>
            
            <div class="hero-stat-card">
              <strong class="stat-big-num">±140,000</strong>
              <span class="stat-card-title">Estimated Coconut Farmer Base</span>
              <p class="stat-card-desc">
                Our coconut supply potential is supported by estimated farmer bases across Kulon Progo, Gunung Kidul, Purworejo, Kebumen, and Cilacap.
              </p>
            </div>

            <div class="hero-stat-card">
              <strong class="stat-big-num">6 Areas</strong>
              <span class="stat-card-title">Coconut Raw Material Network</span>
              <p class="stat-card-desc">
                Our sourcing network covers Kulon Progo, Wates, Kebumen, Cilacap, Purworejo, and Gunung Kidul.
              </p>
            </div>

            <div class="hero-dark-info-card">
              <div class="info-card-header">
                <span class="info-label">SUPPLY NETWORK</span>
                <a href="/farm" class="info-circle-btn">→</a>
              </div>

              <h3 class="info-card-title">
                INDOCOCOPEAT builds cocopeat and coconut fiber supply from selected coconut-producing areas across Java.
              </h3>

              <p class="info-card-text">
                Our raw material network includes Kulon Progo, Wates, Kebumen, Cilacap, Purworejo, and Gunung Kidul to support cocopeat polybag, cocofiber, coir rope, block, and briquette products.
              </p>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ======================================================
     ABOUT SECTION
====================================================== -->
<section class="section premium-about-section" aria-label="About INDOCOCOPEAT">
  <div class="container">
    
    <div class="about-top-kicker">
      <span class="section-badge-kicker">About us</span>
    </div>

    <div class="about-split-grid">
      <div class="about-grid-left">
        <h2 class="about-heading-main">
          CV LOKA ADI JAYA develops sustainable cocopeat and coconut fiber products from Indonesia.
        </h2>

        <p class="about-left-desc">
          We transform coconut husk byproducts into useful materials for agriculture, horticulture, hydroponic cultivation, and industrial applications.
        </p>

        <div class="about-highlight-grid">
          <div class="about-highlight-card">
            <span class="about-highlight-num">6</span>
            <span class="about-highlight-label">Supply Areas</span>
          </div>

          <div class="about-highlight-card">
            <span class="about-highlight-num">±140K</span>
            <span class="about-highlight-label">Estimated Farmer Base</span>
          </div>

          <div class="about-highlight-card">
            <span class="about-highlight-num">22.5T</span>
            <span class="about-highlight-label">Polybag Load Ability</span>
          </div>
        </div>
      </div>

      <div class="about-grid-right">
        <div class="about-content-card">
          <p class="paragraph-highlight">
            CV LOKA ADI JAYA focuses on transforming coconut husk byproducts into growing media and natural fiber materials for agriculture, horticulture, hydroponic cultivation, and industrial applications.
          </p>

          <p class="paragraph-regular">
            Our raw material network covers selected coconut-producing areas across Java, including Kulon Progo, Wates, Kebumen, Cilacap, Purworejo, and Gunung Kidul. Through coconut husk collection, fiber separation, drying, compression, and packaging, we prepare cocopeat and coconut fiber products for domestic and export market needs.
          </p>

          <div class="about-point-list">
            <div class="about-point-item">
              <span class="about-point-dot"></span>
              <span>Coconut husk collection and raw material sourcing</span>
            </div>

            <div class="about-point-item">
              <span class="about-point-dot"></span>
              <span>Fiber separation, drying, compression, and packaging</span>
            </div>

            <div class="about-point-item">
              <span class="about-point-dot"></span>
              <span>Cocopeat, cocofiber, coir rope, block, and briquette products</span>
            </div>
          </div>
        </div>

        <div class="about-image-row">
          <div class="about-mini-image about-mini-image-main">
            <img src="/images/farms/kebun.jpg" alt="Local coconut sourcing area" />
          </div>

          <div class="about-mini-image about-mini-image-small">
            <img src="/images/hero/bg-fiber.webp" alt="Processed coconut fiber and cocopeat products" />
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

    <!-- ======================================================
     SUPPLY PATH SECTION
====================================================== -->
<section class="section dark-dashboard-section" aria-label="Supply path and product control">
  <div class="container">
    <div class="dashboard-shell-grid">
      
      <!-- Left: Supply Path -->
      <div class="dashboard-left-panel">
        <span class="dashboard-kicker">SUPPLY PATH</span>
        <h3 class="panel-heading">
          From Java coconut sourcing areas to buyer-ready products
        </h3>
        <p class="panel-subtext">
          CV LOKA ADI JAYA connects coconut-producing areas with processing, specification control, packing, and domestic or export delivery needs.
        </p>

        <div class="supply-flow-card">
          <div class="flow-step">
            <span class="flow-num">01</span>
            <div>
              <h4>Raw Material</h4>
              <p>Coconut husks collected from selected sourcing areas.</p>
            </div>
          </div>

          <div class="flow-step">
            <span class="flow-num">02</span>
            <div>
              <h4>Separation</h4>
              <p>Fiber and cocopeat materials are separated and prepared.</p>
            </div>
          </div>

          <div class="flow-step">
            <span class="flow-num">03</span>
            <div>
              <h4>Drying</h4>
              <p>Materials are dried based on product moisture requirements.</p>
            </div>
          </div>

          <div class="flow-step">
            <span class="flow-num">04</span>
            <div>
              <h4>Compression</h4>
              <p>Cocopeat and fiber products are compressed and packed.</p>
            </div>
          </div>

          <div class="flow-step">
            <span class="flow-num">05</span>
            <div>
              <h4>Delivery</h4>
              <p>Finished products are prepared for domestic and export buyers.</p>
            </div>
          </div>
        </div>

        
        </div>
      </div>

      <!-- Right: Product Control -->
      <div class="dashboard-right-panel">
        <div class="dashboard-chart-card">
          <span class="chart-kicker">QUALITY CONTROL</span>
          <h4 class="chart-title">Product Specification Control</h4>
          <p class="chart-subtitle">
            Standard product parameters are checked during sorting, drying, compression, and packaging.
          </p>

          <div class="spec-control-list">
            <div class="spec-control-item">
              <span class="spec-label">pH Range</span>
              <strong>5.2 to 6.8</strong>
            </div>

            <div class="spec-control-item">
              <span class="spec-label">Electrical Conductivity</span>
              <strong>4 - 5 mS/cm</strong>
            </div>

            <div class="spec-control-item">
              <span class="spec-label">Moisture</span>
              <strong>Based on product type</strong>
            </div>

            <div class="spec-control-item">
              <span class="spec-label">Packing</span>
              <strong>Buyer requirement</strong>
            </div>
          </div>

          <div class="dashboard-join-card">
            <div class="join-info">
              <h5>Connect With CV LOKA ADI JAYA</h5>
              <p>Request product specifications, packing options, and container loading details.</p>
            </div>
            <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="join-action-btn">
              Connect Now
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

    <!-- ======================================================
     WHY CHOOSE US
====================================================== -->
<section class="section premium-why-section" aria-label="Why choose INDOCOCOPEAT">
  <div class="container">
    
    <div class="why-header-grid">
      <div class="why-header-left">
        <span class="section-badge-kicker">Our Strengths</span>
        <h2 class="why-heading-title">Reliable cocopeat and coconut fiber solutions for consistent supply.</h2>
      </div>

      <p class="why-header-text">
        We focus on sustainable raw materials, selected Java sourcing areas, product specification control, and practical product options for domestic and export buyers.
      </p>
    </div>

    <div class="premium-why-cards-grid">
      {whyChooseUs.map((item, i) => (
        <article class={`why-item-card ${i === 0 ? 'why-item-card--featured' : ''}`}>
          <div class="why-item-top">
            <span class="why-item-num">0{i + 1}</span>
            <span class="why-item-mark"></span>
          </div>
          <h3 class="why-item-title">{item.title}</h3>
          <p class="why-item-desc">{item.description}</p>
        </article>
      ))}
    </div>

  </div>
</section>

    <!-- ======================================================
         PROCESS PATHWAY SECTION
    ====================================================== -->
    <section class="section premium-process-section" aria-label="Production workflow">
      <div class="container">
        
        <div class="process-section-header">
          <span class="section-badge-kicker">Workflow</span>
          <h2 class="process-title-main">We process agricultural cocopeat with modern standards and respect for nature</h2>
        </div>

        <div class="premium-process-grid">
          {businessProcess.map((step) => (
            <div class="premium-process-card">
              <div class="proc-icon-row">
                <span class="proc-step-num">0{step.step}</span>
                <span class="proc-bullet-dot"></span>
              </div>
              <h3 class="proc-card-title">{step.title}</h3>
              <p class="proc-card-desc">{step.description}</p>
            </div>
          ))}
        </div>

        <div class="process-bottom-sourcing-bar">
          <div class="sourcing-text-side">
            <p>Our values align with <strong>sustainable development</strong>, <strong>direct supply chain</strong>, and <strong>certified quality</strong>.</p>
          </div>
          <div class="sourcing-btn-side">
            <a href="/products" class="btn-dark-pill">View Products</a>
          </div>
        </div>

      </div>
    </section>

    <!-- ======================================================
         CTA SECTION
    ====================================================== -->
    <section class="premium-cta-banner-section" aria-label="Contact call to action">
      
        </div>
      </div>
    </section>

  </main>
</MainLayout>

<style>
  /* Premium Agroton-Inspired Layout Styles */

  .premium-hero {
    position: relative;
    overflow: hidden;
    padding-top: calc(var(--navbar-height) + 5rem);
    padding-bottom: 6rem;
    min-height: 100vh;
    background-image:
      linear-gradient(
        90deg,
        rgba(8, 20, 16, 0.76) 0%,
        rgba(8, 20, 16, 0.58) 44%,
        rgba(8, 20, 16, 0.34) 100%
      ),
      url('/public/images/hero/bg-kelapa.webp');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .premium-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 85% 15%, rgba(200, 137, 42, 0.18), transparent 34%),
      linear-gradient(to bottom, rgba(255,255,255,0.02), rgba(8,20,16,0.12));
    pointer-events: none;
    z-index: 0;
  }

  .hero-container {
    position: relative;
    z-index: 1;
  }

  .hero-top-grid {
    max-width: 880px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    background: rgba(255, 255, 255, 0.18);
    color: var(--color-white);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255,255,255,0.18);
  }

  .hero-main-title {
    font-family: var(--font-heading);
    font-size: clamp(2.8rem, 6vw, 5.6rem);
    color: var(--color-white);
    line-height: 0.98;
    letter-spacing: -0.045em;
    margin-bottom: 1.5rem;
    max-width: 980px;
  }

  .highlight-text {
    font-weight: 300;
    font-style: italic;
    color: rgba(255, 255, 255, 0.82);
  }

  .hero-subtext-para {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.84);
    line-height: 1.75;
    max-width: 700px;
    margin-bottom: 2rem;
  }

  .hero-actions-row {
    display: flex;
    gap: 1.25rem;
    align-items: center;
    margin-bottom: 3rem;
  }

  .btn-dark-pill {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: 0.9rem 2rem;
    background-color: var(--color-primary);
    color: var(--color-white);
    border-radius: var(--radius-full);
    font-weight: 600;
    font-size: 0.95rem;
    transition: background-color var(--transition-base), transform var(--transition-base);
  }

  .premium-hero .btn-dark-pill {
    background-color: var(--color-accent);
    color: var(--color-white);
  }

  .btn-dark-pill:hover {
    background-color: var(--color-primary-dark);
    transform: translateY(-2px);
    color: var(--color-white);
  }

  .premium-hero .btn-dark-pill:hover {
    background-color: var(--color-accent-dark);
  }

  .btn-clean-link {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-white);
    border-bottom: 1.5px solid rgba(255,255,255,0.72);
    padding-bottom: 0.2rem;
    transition: opacity var(--transition-fast);
  }

  .btn-clean-link:hover {
    opacity: 0.8;
    color: var(--color-white);
  }

  /* Interactive Info Cards Grid */
  .hero-interactive-grid {
    margin-top: 4rem;
  }

  .hero-stats-subgrid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5rem;
    align-items: stretch;
  }

  .hero-stat-card {
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(255,255,255,0.34);
    border-radius: 24px;
    padding: 1.75rem 2rem;
    min-height: 180px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    backdrop-filter: blur(16px);
    box-shadow: 0 18px 50px rgba(0,0,0,0.12);
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }

  .hero-stat-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 60px rgba(0,0,0,0.16);
  }

  .stat-big-num {
    display: block;
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: 0.65rem;
  }

  .stat-card-title {
    display: block;
    font-size: 1rem;
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 0.45rem;
    line-height: 1.25;
  }

  .stat-card-desc {
    font-size: 0.88rem;
    color: var(--color-text-secondary);
    line-height: 1.55;
    margin: 0;
  }

  /* Dark Info Card */
  .hero-dark-info-card {
    grid-column: 1 / -1;
    background: rgba(14, 31, 24, 0.92);
    color: var(--color-white);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 28px;
    padding: 2.25rem 2.5rem;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    backdrop-filter: blur(14px);
    box-shadow: 0 24px 70px rgba(0,0,0,0.22);
  }

  .info-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
    position: relative;
    z-index: 1;
  }

  .info-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: var(--color-accent-warm);
  }

  .info-circle-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.2rem;
    height: 2.2rem;
    background: rgba(255,255,255,0.1);
    color: white;
    border-radius: 50%;
    font-size: 1rem;
    transition: background var(--transition-fast), transform var(--transition-fast);
  }

  .info-circle-btn:hover {
    background: rgba(255,255,255,0.25);
    color: white;
    transform: translateX(2px);
  }

  .info-card-title {
    font-size: clamp(1.35rem, 2.2vw, 2rem);
    font-weight: 700;
    color: var(--color-white);
    line-height: 1.3;
    margin-bottom: 0.85rem;
    max-width: 860px;
    position: relative;
    z-index: 1;
  }

  .info-card-text {
    font-size: 0.98rem;
    color: rgba(255,255,255,0.75);
    line-height: 1.7;
    margin: 0;
    max-width: 900px;
    position: relative;
    z-index: 1;
  }

  /* About Us split layout */
  .premium-about-section {
    background-color: var(--color-white);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
  }

  .premium-about-section::before {
    content: '';
    position: absolute;
    left: -120px;
    top: 80px;
    width: 280px;
    height: 280px;
    background: radial-gradient(circle, rgba(200, 137, 42, 0.08), transparent 70%);
    pointer-events: none;
  }

  .section-badge-kicker {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .about-split-grid {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 4.5rem;
    align-items: start;
    position: relative;
    z-index: 1;
  }

  .about-heading-main {
    font-family: var(--font-heading);
    font-size: clamp(2.4rem, 4vw, 4.2rem);
    color: var(--color-primary);
    line-height: 1.05;
    letter-spacing: -0.045em;
    margin-bottom: 1.5rem;
    max-width: 720px;
  }

  .about-left-desc {
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 560px;
    margin-bottom: 2rem;
  }

  .about-highlight-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
    max-width: 620px;
  }

  .about-highlight-card {
    background: var(--color-offwhite);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 1.2rem;
  }

  .about-highlight-num {
    display: block;
    font-size: 1.55rem;
    font-weight: 800;
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: 0.55rem;
  }

  .about-highlight-label {
    display: block;
    font-size: 0.76rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.35;
  }

  .about-grid-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .about-content-card {
    background: var(--color-offwhite);
    border: 1px solid var(--color-border);
    border-radius: 28px;
    padding: 2rem;
  }

  .paragraph-highlight {
    font-size: 1.15rem;
    color: var(--color-text-primary);
    line-height: 1.75;
    font-weight: 600;
    margin-bottom: 1.4rem;
  }

  .paragraph-regular {
    font-size: 0.98rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: 1.6rem;
  }

  .about-point-list {
    display: grid;
    gap: 0.75rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--color-border);
  }

  .about-point-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
  }

  .about-point-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: var(--color-accent);
    flex-shrink: 0;
    margin-top: 0.42rem;
  }

  .about-image-row {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 1rem;
    align-items: stretch;
  }

  .about-mini-image {
    border-radius: 24px;
    overflow: hidden;
    background: var(--color-light-gray);
    border: 1px solid var(--color-border);
  }

  .about-mini-image-main {
    height: 230px;
  }

  .about-mini-image-small {
    height: 230px;
  }

  .about-mini-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Dashboard Block */
  .dark-dashboard-section {
    background:
      linear-gradient(135deg, #123825 0%, #0f3a24 52%, #163e28 100%);
    color: var(--color-white);
    border-radius: 40px;
    margin: 2rem var(--space-6);
    padding: var(--space-20) var(--space-10);
    position: relative;
    overflow: hidden;
  }

  .dark-dashboard-section::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 12% 18%, rgba(255,255,255,0.05), transparent 24%),
      radial-gradient(circle at 88% 12%, rgba(200,137,42,0.09), transparent 26%);
    pointer-events: none;
  }

  .dashboard-shell-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.88fr;
    gap: 3rem;
