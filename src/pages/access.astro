---
import '../styles/global.css';
import { ACCESS_CONFIG } from '../config/access';
import { company } from '../data/company';

const title = 'INDOCOCOPEAT - Private Access';
const description = 'Private access portal for INDOCOCOPEAT export partners and buyers.';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="INDOCOCOPEAT" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="access-body">
    <main class="access-page">
      
      <!-- Logo Header -->
      <header class="access-header">
        <div class="access-logo">
          <span class="logo-indo">INDO</span><span class="logo-coco">COCOPEAT</span>
        </div>
        <span class="access-pill">Secure Partner Access</span>
      </header>

      <!-- Glassmorphic Form Card -->
      <section class="access-main">
        <div class="access-container">
          
          <div class="lock-graphic">
            <!-- Modern Minimal Lock Icon -->
            <svg class="lock-svg" viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <rect x="5" y="11" width="14" height="10" rx="2" stroke-width="2"/>
              <path d="M8 11V7C8 4.79 9.79 3 12 3C14.21 3 16 4.79 16 7V11" stroke-width="2"/>
            </svg>
          </div>

          <h1 id="access-title" class="access-heading">Private Portal</h1>
          <p class="access-subtext">Enter your partner access passcode below to access the global catalog and pricing.</p>

          <form id="accessForm" novalidate>
            <div class="input-wrap">
              <input id="accessCode" name="accessCode" type="password" autocomplete="off" placeholder="••••••••••••" required />
              <div class="input-glow"></div>
            </div>
            <p id="accessError" class="access-error" role="alert">Access passcode is incorrect. Please try again.</p>
            <button id="accessButton" type="submit" class="access-submit-btn">Verify Access</button>
          </form>

          <div class="access-help">
            Need an access code? Contact <a href={`mailto:${company.email}`}>{company.email}</a>.
          </div>
        </div>
      </section>

      <!-- Footer Info -->
      <footer class="access-footer">
        <span>{company.legalName}</span>
        <span>{company.address.city}, {company.address.country}</span>
      </footer>
    </main>

    <style>
      .access-body {
        min-height: 100vh;
        margin: 0;
        background-color: var(--color-primary-dark);
        color: var(--color-white);
        font-family: var(--font-body);
        overflow-x: hidden;
      }

      .access-page {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        background: radial-gradient(circle at center, #1e452f 0%, #0e2016 100%);
        padding: 2rem;
      }

      .access-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
      }

      .access-logo {
        font-size: 1.25rem;
        font-weight: 800;
        letter-spacing: -0.01em;
      }

      .logo-indo {
        color: var(--color-white);
      }

      .logo-coco {
        color: var(--color-accent);
      }

      .access-pill {
        padding: 0.4rem 1rem;
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: var(--radius-full);
        background: rgba(255, 255, 255, 0.05);
        color: rgba(255, 255, 255, 0.75);
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .access-main {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 0;
      }

      /* Premium Glassmorphic Portal Box */
      .access-container {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 32px;
        padding: 3.5rem 3rem;
        max-width: 440px;
        width: 100%;
        text-align: center;
        box-shadow: 0 32px 80px rgba(0,0,0,0.3);
      }

      .lock-graphic {
        width: 3.5rem;
        height: 3.5rem;
        border-radius: 50%;
        background: rgba(200, 137, 42, 0.1);
        color: var(--color-accent-warm);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.5rem;
      }

      .lock-svg {
        width: 1.5rem;
        height: 1.5rem;
      }

      .access-heading {
        font-family: var(--font-heading);
        font-size: 2rem;
        font-weight: 700;
        color: var(--color-white);
        margin-bottom: 0.5rem;
      }

      .access-subtext {
        font-size: 0.88rem;
        color: rgba(255, 255, 255, 0.65);
        line-height: 1.6;
        margin-bottom: 2.25rem;
      }

      #accessForm {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      .input-wrap {
        position: relative;
        width: 100%;
      }

      #accessCode {
        width: 100%;
        background: rgba(255,255,255,0.04);
        border: 1.5px solid rgba(255, 255, 255, 0.12);
        border-radius: var(--radius-full);
        padding: 0.95rem 1.5rem;
        font-size: 1rem;
        color: var(--color-white);
        outline: none;
        text-align: center;
        letter-spacing: 0.25em;
        transition: border-color 0.3s, background-color 0.3s;
      }

      #accessCode:focus {
        border-color: var(--color-accent);
        background: rgba(255, 255, 255, 0.08);
      }

      #accessCode.is-error {
        border-color: var(--color-error);
        background: rgba(180, 59, 59, 0.08);
      }

      .access-error {
        display: none;
        color: #ff6b6b;
        font-size: 0.8rem;
        margin-top: 0.25rem;
      }

      .access-error.is-visible {
        display: block;
      }

      .access-submit-btn {
        background-color: var(--color-accent);
        color: var(--color-white);
        padding: 0.95rem;
        border-radius: var(--radius-full);
        font-size: 0.92rem;
        font-weight: 700;
        cursor: pointer;
        transition: background-color 0.2s, transform 0.2s;
        border: none;
        margin-top: 0.5rem;
      }

      .access-submit-btn:hover {
        background-color: var(--color-accent-dark);
        transform: translateY(-1px);
      }

      .access-submit-btn:disabled {
        opacity: 0.65;
        cursor: not-allowed;
      }

      .access-help {
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.45);
      }

      .access-help a {
        color: var(--color-accent-warm);
        font-weight: 600;
        text-decoration: none;
      }

      .access-help a:hover {
        text-decoration: underline;
      }

      .access-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        font-size: 0.75rem;
        color: rgba(255, 255, 255, 0.45);
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding-top: 1.5rem;
      }

      @media (max-width: 500px) {
        .access-page {
          padding: 1.25rem;
        }

        .access-container {
          padding: 2.5rem 1.5rem;
        }

        .access-footer {
          flex-direction: column;
          gap: 0.5rem;
          text-align: center;
        }
      }
    </style>

    <script is:inline define:vars={{
      accessCode: ACCESS_CONFIG.code,
      sessionKey: ACCESS_CONFIG.sessionKey,
      sessionDuration: ACCESS_CONFIG.sessionDuration,
    }}>
      (function () {
        var redirect = new URLSearchParams(window.location.search).get('redirect') || '/';
        var safeRedirect = redirect.startsWith('/') && !redirect.startsWith('//') ? redirect : '/';
        var rawSession = localStorage.getItem(sessionKey);

        try {
          if (rawSession) {
            var session = JSON.parse(rawSession);
            var isValidSession = session.authenticated && Date.now() - Number(session.timestamp || 0) <= sessionDuration;

            if (isValidSession) {
              window.location.replace(safeRedirect);
              return;
            }
          }
        } catch (error) {
          localStorage.removeItem(sessionKey);
        }

        var form = document.getElementById('accessForm');
        var input = document.getElementById('accessCode');
        var button = document.getElementById('accessButton');
        var error = document.getElementById('accessError');

        function showError() {
          error.classList.add('is-visible');
          input.classList.add('is-error');
          input.focus();
        }

        function clearError() {
          error.classList.remove('is-visible');
          input.classList.remove('is-error');
        }

        input.addEventListener('input', clearError);

        form.addEventListener('submit', function (event) {
          event.preventDefault();
          clearError();

          if (input.value.trim().toUpperCase() !== accessCode.toUpperCase()) {
            showError();
            return;
          }

          button.disabled = true;
          button.textContent = 'Opening private view';

          localStorage.setItem(sessionKey, JSON.stringify({
            authenticated: true,
            timestamp: Date.now(),
          }));

          window.setTimeout(function () {
            window.location.href = safeRedirect;
          }, 250);
        });
      })();
    </script>
  </body>
</html>
