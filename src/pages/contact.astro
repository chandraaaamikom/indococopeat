---
import MainLayout from '../layouts/MainLayout.astro';
import { company } from '../data/company';
import { socialLinks } from '../data/social';

const officialAddress = `${company.address.street} - ${company.address.province}, ${company.address.country} ${company.address.postalCode}`;
const whatsappMessage = encodeURIComponent('Hello INDOCOCOPEAT, I would like to request product catalog and export quotation.');
const whatsappUrl = `https://wa.me/${company.whatsappNumber}?text=${whatsappMessage}`;
const emailUrl = `mailto:${company.email}?subject=${encodeURIComponent('Product catalog and export quotation request')}`;
---

<MainLayout
  title="Contact - INDOCOCOPEAT"
  description="Contact PT. Abbasy Jaya Makmur for INDOCOCOPEAT product catalog, export quotation, WhatsApp inquiry, or email request."
  currentPage="contact"
>
  <main class="page-content contact-page">
    <section class="page-hero">
      <div class="container">
        <span class="section-badge-kicker">✦ Contact</span>
        <h1 class="hero-section-title">Contact Us</h1>
        <p class="hero-section-text">
          Request product catalog, export quotation, or product information from the INDOCOCOPEAT team.
        </p>
      </div>
    </section>

    <section class="container contact-section" aria-label="Contact details and inquiry form">
      <div class="contact-shell">
        <aside class="contact-panel" aria-label="Official contact information">
          <div class="contact-panel__body">
            <span class="panel-kicker">OFFICIAL PARTNER</span>
            <h2 class="panel-title">{company.legalName}</h2>
            <p class="contact-panel__intro">
              Official contact details for export inquiries and product catalog requests.
            </p>

            <div class="contact-list">
              <article class="contact-item">
                <span class="item-num" aria-hidden="true">01</span>
                <div>
                  <h3 class="item-title">Address</h3>
                  <p class="item-text">{officialAddress}</p>
                </div>
              </article>
              <article class="contact-item">
                <span class="item-num" aria-hidden="true">02</span>
                <div>
                  <h3 class="item-title">Hotline</h3>
                  <p class="item-text"><a href={`tel:+${company.whatsappNumber}`}>{company.hotline}</a></p>
                </div>
              </article>
              <article class="contact-item">
                <span class="item-num" aria-hidden="true">03</span>
                <div>
                  <h3 class="item-title">WhatsApp</h3>
                  <p class="item-text"><a href={whatsappUrl} target="_blank" rel="noopener noreferrer">+{company.whatsappNumber}</a></p>
                </div>
              </article>
              <article class="contact-item">
                <span class="item-num" aria-hidden="true">04</span>
                <div>
                  <h3 class="item-title">Email</h3>
                  <p class="item-text"><a href={emailUrl}>{company.email}</a></p>
                </div>
              </article>
            </div>

            <div class="contact-panel__actions">
              <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn contact-whatsapp">
                Chat WhatsApp
              </a>
              <a href={emailUrl} class="btn contact-email">
                Send Email
              </a>
            </div>
          </div>

          <div class="contact-social">
            <span class="social-title">Connect with us</span>
            <div class="social-pills-row">
              {socialLinks.map((social) => (
                <a href={social.url} target="_blank" rel="noopener noreferrer" class="social-pill" aria-label={`Open ${social.name}`}>
                  {social.label}
                </a>
              ))}
            </div>
          </div>
        </aside>

        <section class="contact-form-card" aria-labelledby="contact-form-title">
          <h2 id="contact-form-title" class="form-title">Send a message</h2>
          <p class="form-intro">Use this form to prepare your inquiry. Our team will follow up shortly.</p>

          <form id="contactForm" novalidate>
            <div class="contact-form-grid">
              <div class="form-field">
                <label for="name" class="field-label">Name <span class="required-star">*</span></label>
                <input id="name" name="name" type="text" autocomplete="name" class="animated-input" required />
                <p class="field-error">Please enter your name.</p>
              </div>

              <div class="form-field">
                <label for="email" class="field-label">Email <span class="required-star">*</span></label>
                <input id="email" name="email" type="email" autocomplete="email" class="animated-input" required />
                <p class="field-error">Please enter a valid email address.</p>
              </div>

              <div class="form-field">
                <label for="companyName" class="field-label">Company</label>
                <input id="companyName" name="companyName" type="text" class="animated-input" autocomplete="organization" />
              </div>

              <div class="form-field">
                <label for="country" class="field-label">Country</label>
                <input id="country" name="country" type="text" class="animated-input" autocomplete="country-name" />
              </div>

              <div class="form-field form-field--wide">
                <label for="message" class="field-label">Message <span class="required-star">*</span></label>
                <textarea id="message" name="message" rows="6" class="animated-textarea" required></textarea>
                <p class="field-error">Please write your message.</p>
              </div>
            </div>

            <label class="privacy-check" for="privacy">
              <input id="privacy" name="privacy" type="checkbox" required />
              <span class="privacy-text">I agree that INDOCOCOPEAT may use this information to respond to my inquiry.</span>
            </label>
            <p id="privacyError" class="field-error privacy-error">Please confirm the privacy agreement.</p>

            <div class="contact-form-footer">
              <p id="formStatus" role="status" aria-live="polite">Fill the required fields to prepare your message.</p>
              <button id="submitBtn" type="submit" class="btn submit-action-btn">
                Send Message
              </button>
            </div>

            <div id="successMsg" class="success-message" role="status" aria-live="polite">
              Thank you. Your inquiry has been prepared. Please use WhatsApp or email for official submission.
            </div>
          </form>
        </section>
      </div>
    </section>
  </main>

  <style>
    .contact-page {
      background-color: var(--color-offwhite);
      min-height: 100vh;
      padding-top: var(--navbar-height);
    }

    .page-hero {
      padding: 5rem 0 3rem;
      text-align: center;
    }

    .section-badge-kicker {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--color-accent);
      margin-bottom: 1rem;
    }

    .hero-section-title {
      font-family: var(--font-heading);
      font-size: clamp(2.5rem, 5vw, 4rem);
      margin-bottom: 1.25rem;
      color: var(--color-primary);
      line-height: 1.1;
      font-weight: 700;
    }

    .hero-section-text {
      color: var(--color-text-secondary);
      line-height: 1.7;
      font-size: 1.05rem;
      max-width: 620px;
      margin: 0 auto;
    }

    .contact-section {
      padding-bottom: 6rem;
    }

    .contact-shell {
      display: grid;
      grid-template-columns: minmax(320px, 0.9fr) minmax(0, 1.3fr);
      gap: 2.5rem;
      align-items: stretch;
    }

    .contact-panel {
      border-radius: 32px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
      color: var(--color-white);
      box-shadow: 0 4px 24px rgba(0,0,0,0.02);
    }

    .contact-panel__body {
      padding: 3rem;
      flex: 1;
    }

    .panel-kicker {
      font-size: 0.7rem;
      font-weight: 700;
      color: var(--color-accent-warm);
      letter-spacing: 0.1em;
      display: block;
      margin-bottom: 0.5rem;
    }

    .panel-title {
      margin-bottom: 1rem;
      color: var(--color-white);
      font-size: 2.2rem;
      font-weight: 700;
    }

    .contact-panel__intro {
      margin-bottom: 2.5rem;
      color: rgba(255, 255, 255, 0.75);
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .contact-list {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      margin-bottom: 3rem;
    }

    .contact-item {
      display: flex;
      gap: 1.25rem;
      align-items: flex-start;
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      padding-bottom: 1.25rem;
    }

    .contact-item:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    .item-num {
      width: 2.2rem;
      height: 2.2rem;
      border-radius: 50%;
      border: 1px solid rgba(200, 137, 42, 0.35);
      color: var(--color-accent-warm);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 0.75rem;
      font-weight: 700;
      flex-shrink: 0;
    }

    .item-title {
      margin-bottom: 0.35rem;
      color: var(--color-accent-warm);
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .item-text {
      margin: 0;
      color: rgba(255, 255, 255, 0.9);
      font-size: 0.95rem;
      line-height: 1.6;
    }

    .item-text a {
      color: inherit;
    }

    .contact-panel__actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .contact-whatsapp {
      background: #3d8a45;
      color: var(--color-white);
      border-radius: var(--radius-full);
      font-weight: 600;
      padding: 0.8rem;
      text-align: center;
      justify-content: center;
    }

    .contact-whatsapp:hover {
      background: #34753b;
      color: var(--color-white);
    }

    .contact-email {
      border: 1.5px solid var(--color-accent-warm);
      color: var(--color-accent-warm);
      border-radius: var(--radius-full);
      font-weight: 600;
      padding: 0.8rem;
      text-align: center;
      justify-content: center;
    }

    .contact-email:hover {
      background-color: rgba(200, 137, 42, 0.1);
      color: var(--color-accent-warm);
    }

    .contact-social {
      padding: 1.5rem 3rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(255,255,255,0.03);
      border-top: 1px solid rgba(255,255,255,0.08);
    }

    .social-title {
      font-weight: 700;
      font-size: 0.88rem;
      color: rgba(255, 255, 255, 0.65);
    }

    .social-pills-row {
      display: flex;
      gap: 0.6rem;
    }

    .social-pill {
      font-size: 0.75rem;
      font-weight: 700;
      border: 1px solid rgba(255, 255, 255, 0.25);
      color: var(--color-white);
      padding: 0.35rem 0.85rem;
      border-radius: var(--radius-full);
      transition: background-color 0.2s, border-color 0.2s;
    }

    .social-pill:hover {
      border-color: var(--color-accent);
      background-color: rgba(255,255,255,0.05);
      color: var(--color-white);
    }

    /* Form Card Styles (Apple Minimalist Style) */
    .contact-form-card {
      background-color: var(--color-white);
      border: 1px solid var(--color-border);
      border-radius: 32px;
      padding: 3.5rem;
      box-shadow: 0 4px 24px rgba(0,0,0,0.02);
    }

    .form-title {
      font-family: var(--font-heading);
      font-size: 2.2rem;
      color: var(--color-primary);
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .form-intro {
      font-size: 0.95rem;
      color: var(--color-text-secondary);
      margin-bottom: 3rem;
    }

    .contact-form-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 2rem;
    }

    .form-field--wide {
      grid-column: span 2;
    }

    .field-label {
      display: block;
      font-size: 0.82rem;
      font-weight: 700;
      color: var(--color-primary);
      margin-bottom: 0.5rem;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .required-star {
      color: var(--color-accent);
    }

    /* Apple-like bottom-line inputs */
    .animated-input,
    .animated-textarea {
      width: 100%;
      background: transparent;
      border: none;
      border-bottom: 2px solid var(--color-border);
      padding: 0.8rem 0;
      font-size: 1rem;
      color: var(--color-text-primary);
      outline: none;
      transition: border-bottom-color 0.3s cubic-bezier(0.16, 1, 0.3, 1);
      border-radius: 0;
    }

    .animated-textarea {
      min-height: 9rem;
      resize: vertical;
      line-height: 1.6;
    }

    .animated-input:focus,
    .animated-textarea:focus {
      border-bottom-color: var(--color-primary);
    }

    .form-field.is-invalid .animated-input,
    .form-field.is-invalid .animated-textarea {
      border-bottom-color: var(--color-error);
    }

    .field-error {
      display: none;
      font-size: 0.8rem;
      color: var(--color-error);
      margin-top: 0.5rem;
    }

    .form-field.is-invalid .field-error,
    .privacy-error.is-visible {
      display: block;
    }

    .privacy-check {
      display: flex;
      align-items: flex-start;
      gap: 0.75rem;
      margin-top: 2rem;
      cursor: pointer;
    }

    .privacy-check input {
      margin-top: 0.25rem;
      accent-color: var(--color-primary);
    }

    .privacy-text {
      font-size: 0.88rem;
      color: var(--color-text-secondary);
      line-height: 1.5;
    }

    .privacy-error {
      margin-top: 0.5rem;
    }

    .contact-form-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 2rem;
      margin-top: 2.5rem;
      border-top: 1px solid var(--color-offwhite);
      padding-top: 2rem;
    }

    #formStatus {
      margin: 0;
      font-size: 0.88rem;
      color: var(--color-text-muted);
    }

    #formStatus.is-ready {
      color: var(--color-primary);
      font-weight: 600;
    }

    #formStatus.is-error {
      color: var(--color-error);
      font-weight: 600;
    }

    .submit-action-btn {
      background-color: var(--color-primary);
      color: white;
      padding: 0.9rem 2.5rem;
      border-radius: var(--radius-full);
      font-weight: 600;
      transition: background-color 0.2s, transform 0.2s;
    }

    .submit-action-btn:hover {
      background-color: var(--color-primary-dark);
      transform: translateY(-1px);
      color: white;
    }

    .success-message {
      display: none;
      margin-top: 1.5rem;
      padding: 1.25rem;
      border-radius: 16px;
      background: rgba(26, 54, 38, 0.05);
      color: var(--color-primary);
      font-size: 0.9rem;
      line-height: 1.6;
      border: 1px solid var(--color-primary);
    }

    .success-message.is-visible {
      display: block;
    }

    @media (max-width: 1000px) {
      .contact-shell {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
    }

    @media (max-width: 640px) {
      .contact-form-card {
        padding: 2rem;
      }

      .contact-form-grid {
        grid-template-columns: 1fr;
      }

      .contact-form-footer {
        flex-direction: column;
        align-items: stretch;
        gap: 1.5rem;
      }

      .submit-action-btn {
        width: 100%;
        text-align: center;
      }
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      var form = document.getElementById('contactForm');
      var status = document.getElementById('formStatus');
      var success = document.getElementById('successMsg');
      var submitBtn = document.getElementById('submitBtn');
      var privacy = document.getElementById('privacy');
      var privacyError = document.getElementById('privacyError');

      function getWrapper(field) {
        return field.closest('.form-field');
      }

      function validateField(field, showError) {
        var wrapper = getWrapper(field);
        var valid = field.checkValidity();

        if (wrapper && showError) {
          wrapper.classList.toggle('is-invalid', !valid);
        }

        return valid;
      }

      function updateStatus() {
        var requiredFields = form.querySelectorAll('input[required]:not([type="checkbox"]), textarea[required]');
        var fieldsReady = Array.prototype.every.call(requiredFields, function (field) {
          return field.checkValidity() && field.value.trim() !== '';
        });
        var ready = fieldsReady && privacy.checked;

        status.classList.remove('is-error', 'is-ready');

        if (ready) {
          status.classList.add('is-ready');
          status.textContent = 'All good. Your message is ready.';
        } else {
          status.textContent = 'Fill the required fields to prepare your message.';
        }
      }

      form.querySelectorAll('input, textarea').forEach(function (field) {
        field.addEventListener('input', function () {
          validateField(field, false);
          if (field === privacy) {
            privacyError.classList.remove('is-visible');
          }
          updateStatus();
        });

        field.addEventListener('blur', function () {
          if (field.type !== 'checkbox') {
            validateField(field, field.hasAttribute('required') && field.value.trim() !== '');
          }
          updateStatus();
        });
      });

      form.addEventListener('submit', function (event) {
        event.preventDefault();
        success.classList.remove('is-visible');

        var requiredFields = form.querySelectorAll('input[required]:not([type="checkbox"]), textarea[required]');
        var validFields = Array.prototype.every.call(requiredFields, function (field) {
          return validateField(field, true);
        });
        var validPrivacy = privacy.checked;

        privacyError.classList.toggle('is-visible', !validPrivacy);

        if (!validFields || !validPrivacy) {
          status.classList.add('is-error');
          status.textContent = 'Please complete the required fields before sending.';
          return;
        }

        submitBtn.disabled = true;
        submitBtn.textContent = 'Preparing message';

        window.setTimeout(function () {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send Message';
          success.classList.add('is-visible');
          form.reset();
          form.querySelectorAll('.form-field').forEach(function (wrapper) {
            wrapper.classList.remove('is-invalid');
          });
          privacyError.classList.remove('is-visible');
          updateStatus();
        }, 650);
      });

      updateStatus();
    });
  </script>
</MainLayout>
