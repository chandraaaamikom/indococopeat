---
import MainLayout from '../layouts/MainLayout.astro';
import { company } from '../data/company';
import { socialLinks } from '../data/social';
---

<MainLayout title="Contact Us | INDOCOCOPEAT" currentPage="contact">
  <div class="page-content" style="background-color: var(--color-offwhite); min-height: 100vh;">
    
    <!-- Header -->
    <div class="container" style="padding-top: 4rem; padding-bottom: 2rem;">
      <div style="max-width: 600px;">
        <h1 style="font-family: var(--font-heading); font-size: 3rem; margin-bottom: 1rem; color: var(--color-primary);">Get in Touch</h1>
        <p style="color: var(--color-text-secondary); line-height: 1.6; font-size: 1.125rem;">
          Whether you need a quotation, product samples, or have a general inquiry, our export team is ready to assist you.
        </p>
      </div>
    </div>

    <div class="container section" style="padding-top: 2rem;">
      <div class="grid contact-grid" style="gap: 4rem; align-items: start;">
        
        <!-- Left: Contact Info -->
        <div class="contact-info">
          
          <div style="background: white; border: 1px solid var(--color-border); border-radius: 24px; padding: 3rem; box-shadow: var(--shadow-sm);">
            <div style="margin-bottom: 3rem;">
              <h3 style="font-size: 0.75rem; font-weight: 600; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1.5rem;">Global Headquarters</h3>
              
              <div style="display: flex; gap: 1.5rem; margin-bottom: 2rem;">
                <div style="width: 48px; height: 48px; background: var(--color-light-gray); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; flex-shrink: 0; color: var(--color-primary);">📍</div>
                <div>
                  <div style="font-weight: 600; color: var(--color-primary); margin-bottom: 0.5rem; font-size: 1.125rem;">Address</div>
                  <div style="color: var(--color-text-secondary); line-height: 1.6; font-size: 0.9375rem;">
                    {company.address.street}<br/>
                    {company.address.city}, {company.address.province} {company.address.postalCode}<br/>
                    {company.address.country}
                  </div>
                </div>
              </div>
              
              <div style="display: flex; gap: 1.5rem; margin-bottom: 2rem;">
                <div style="width: 48px; height: 48px; background: var(--color-light-gray); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; flex-shrink: 0; color: var(--color-primary);">📞</div>
                <div>
                  <div style="font-weight: 600; color: var(--color-primary); margin-bottom: 0.5rem; font-size: 1.125rem;">Call Us</div>
                  <div style="color: var(--color-text-secondary); line-height: 1.6; font-size: 0.9375rem;">
                    <a href={`tel:+${company.whatsappNumber}`} style="color: inherit; text-decoration: none;">+{company.whatsappNumber}</a>
                  </div>
                  <div style="font-size: 0.75rem; color: var(--color-text-muted); margin-top: 0.25rem;">(Available on WhatsApp)</div>
                </div>
              </div>
              
              <div style="display: flex; gap: 1.5rem;">
                <div style="width: 48px; height: 48px; background: var(--color-light-gray); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.25rem; flex-shrink: 0; color: var(--color-primary);">✉️</div>
                <div>
                  <div style="font-weight: 600; color: var(--color-primary); margin-bottom: 0.5rem; font-size: 1.125rem;">Email Us</div>
                  <div style="color: var(--color-text-secondary); line-height: 1.6; font-size: 0.9375rem;">
                    <a href={`mailto:${company.email}`} style="color: inherit; text-decoration: none;">{company.email}</a>
                  </div>
                </div>
              </div>
            </div>

            <!-- Social Links -->
            <div>
              <h3 style="font-size: 0.75rem; font-weight: 600; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1.5rem;">Connect With Us</h3>
              <div style="display: flex; gap: 1rem;">
                {socialLinks.map(social => (
                  <a href={social.url} target="_blank" rel="noopener noreferrer" style="width: 44px; height: 44px; border: 1px solid var(--color-border); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: var(--color-primary); transition: all 0.2s;" class="social-hover">
                    {social.icon}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Contact Form -->
        <div class="contact-form-wrapper">
          <div style="background: white; border: 1px solid var(--color-border); border-radius: 24px; padding: 3rem; box-shadow: var(--shadow-md);">
            <h2 style="font-family: var(--font-heading); font-size: 2rem; color: var(--color-primary); margin-bottom: 0.5rem;">Send a Message</h2>
            <p style="color: var(--color-text-secondary); margin-bottom: 2rem; font-size: 0.9375rem;">Fill out the form below and we'll get back to you within 24 hours.</p>
            
            <form id="contactForm" onsubmit="event.preventDefault(); submitForm();">
              <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
                <div class="input-group" style="grid-column: span 1;">
                  <label for="firstName" style="display: block; font-size: 0.8125rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 0.5rem;">First Name *</label>
                  <input type="text" id="firstName" required style="width: 100%; padding: 0.875rem 1rem; border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-offwhite); outline: none; font-family: inherit; font-size: 0.9375rem; transition: border-color 0.2s;" />
                </div>
                
                <div class="input-group" style="grid-column: span 1;">
                  <label for="lastName" style="display: block; font-size: 0.8125rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 0.5rem;">Last Name *</label>
                  <input type="text" id="lastName" required style="width: 100%; padding: 0.875rem 1rem; border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-offwhite); outline: none; font-family: inherit; font-size: 0.9375rem; transition: border-color 0.2s;" />
                </div>
                
                <div class="input-group" style="grid-column: span 1;">
                  <label for="email" style="display: block; font-size: 0.8125rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 0.5rem;">Email Address *</label>
                  <input type="email" id="email" required style="width: 100%; padding: 0.875rem 1rem; border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-offwhite); outline: none; font-family: inherit; font-size: 0.9375rem; transition: border-color 0.2s;" />
                </div>
                
                <div class="input-group" style="grid-column: span 1;">
                  <label for="company" style="display: block; font-size: 0.8125rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 0.5rem;">Company Name</label>
                  <input type="text" id="company" style="width: 100%; padding: 0.875rem 1rem; border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-offwhite); outline: none; font-family: inherit; font-size: 0.9375rem; transition: border-color 0.2s;" />
                </div>
                
                <div class="input-group" style="grid-column: span 2;">
                  <label for="subject" style="display: block; font-size: 0.8125rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 0.5rem;">Subject *</label>
                  <select id="subject" required style="width: 100%; padding: 0.875rem 1rem; border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-offwhite); outline: none; font-family: inherit; font-size: 0.9375rem; transition: border-color 0.2s; appearance: none;">
                    <option value="" disabled selected>Select an inquiry type</option>
                    <option value="quotation">Request Quotation</option>
                    <option value="sample">Request Product Sample</option>
                    <option value="partnership">Partnership Inquiry</option>
                    <option value="general">General Question</option>
                  </select>
                </div>
                
                <div class="input-group" style="grid-column: span 2;">
                  <label for="message" style="display: block; font-size: 0.8125rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 0.5rem;">Message *</label>
                  <textarea id="message" rows="5" required style="width: 100%; padding: 0.875rem 1rem; border: 1px solid var(--color-border); border-radius: 8px; background: var(--color-offwhite); outline: none; font-family: inherit; font-size: 0.9375rem; resize: vertical; transition: border-color 0.2s;"></textarea>
                </div>
              </div>
              
              <button id="submitBtn" type="submit" class="btn" style="background: var(--color-primary); color: white; width: 100%; justify-content: center; padding: 1rem; border-radius: 8px; font-size: 1rem;">
                Send Message &rarr;
              </button>
              
              <div id="successMsg" style="display: none; margin-top: 1.5rem; padding: 1rem; background: var(--color-success); color: white; border-radius: 8px; text-align: center; font-size: 0.9375rem;">
                Thank you! Your message has been sent successfully. We will be in touch shortly.
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .contact-grid {
      grid-template-columns: 1fr 1.5fr;
    }
    
    input:focus, select:focus, textarea:focus {
      border-color: var(--color-primary) !important;
      background: white !important;
    }
    
    .social-hover:hover {
      background: var(--color-primary);
      color: white !important;
    }
    
    @media (max-width: 1024px) {
      .contact-grid {
        grid-template-columns: 1fr;
      }
    }
    
    @media (max-width: 600px) {
      .form-grid > div {
        grid-column: span 2 !important;
      }
      .contact-info > div,
      .contact-form-wrapper > div {
        padding: 2rem;
      }
    }
  </style>

  <script is:inline>
    function submitForm() {
      const btn = document.getElementById('submitBtn');
      const msg = document.getElementById('successMsg');
      const form = document.getElementById('contactForm');
      
      btn.innerHTML = 'Sending...';
      btn.style.opacity = '0.7';
      btn.disabled = true;
      
      // Simulate API call
      setTimeout(() => {
        btn.style.display = 'none';
        msg.style.display = 'block';
        form.reset();
        
        // Reset button after 5 seconds
        setTimeout(() => {
          btn.style.display = 'flex';
          btn.innerHTML = 'Send Another Message &rarr;';
          btn.style.opacity = '1';
          btn.disabled = false;
          msg.style.display = 'none';
        }, 5000);
      }, 1500);
    }
  </script>
</MainLayout>
