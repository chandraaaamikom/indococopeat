---
import MainLayout from '../layouts/MainLayout.astro';
import { products, productCategories } from '../data/products';
---

<MainLayout
  title="Products - INDOCOCOPEAT"
  description="Explore INDOCOCOPEAT cocopeat and coconut derivative products, including cocopeat polybag, cocopeat block, cocofiber, coconut coir rope, and coconut shell briquettes."
  currentPage="products"
>
  <main class="page-content products-page">
    
    <!-- Header -->
    <div class="page-hero-section">
      <div class="container products-hero-content">
        <span class="section-badge-kicker">OUR PRODUCTS</span>
        <h1 class="hero-section-title">
          Cocopeat & Coconut Derivative Products
        </h1>
        <p class="hero-section-text">
          Explore CV LOKA ADI JAYA product catalog, including cocopeat growing media, cocofiber, coconut coir rope, cocopeat polybag, cocopeat block, and coconut shell briquettes for agriculture, horticulture, export, and industrial needs.
        </p>
      </div>
    </div>

    <!-- Toolbar: Search & Filter -->
    <div class="container products-toolbar">
      <!-- Search -->
      <div class="products-search-wrap">
        <input 
          type="text" 
          id="searchInput"
          placeholder="Search product..." 
          class="products-search-input"
        />
        <svg class="products-search-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
        </svg>
      </div>

      <!-- Filter -->
      <div class="products-filter-wrap hide-scrollbar">
        {productCategories.map((category, index) => (
          <button 
            class={`filter-btn ${index === 0 ? 'active' : ''}`}
            data-category={category}
          >
            {category}
          </button>
        ))}
      </div>
    </div>

    <!-- Product Grid -->
    <div class="container product-grid-section">
      <div id="noResults" class="no-results-box">
        <h3>No products found</h3>
        <p>Try adjusting your search keyword or product category.</p>
      </div>

      <div class="product-layout" id="productGrid">
        {products.map((product, index) => (
          <article 
            class="product-card" 
            data-category={product.category}
            data-name={product.name.toLowerCase()}
            data-search={`${product.name} ${product.category} ${product.description} ${product.features.join(' ')} ${Object.values(product.specifications).join(' ')}`.toLowerCase()}
            role="button"
            tabindex="0"
            onclick={`openModal('${product.id}')`}
            onkeydown={`if(event.key === 'Enter' || event.key === ' ') { event.preventDefault(); openModal('${product.id}'); }`}
          >
            <div class="product-card__image-container">
              <img
                src={product.image}
                alt={product.name}
                loading="lazy"
                class="product-card__image"
              />
              <div class="product-card__overlay">
                <span class="product-card__hover-action">Explore Specs</span>
              </div>
            </div>

            <div class="product-card__content">
              <span class="product-card__number">
                {String(index + 1).padStart(2, '0')}
              </span>

              <div class="product-card__header-row">
                <h2 class="product-card__title">
                  {product.name}
                </h2>
                <span class="product-card__badge">{product.category}</span>
              </div>

              <p class="product-card__desc">
                {product.description}
              </p>

              <div class="product-card__tags">
                {product.features.slice(0, 3).map((feat) => (
                  <span class="tag-pill">{feat}</span>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>

  <!-- Modal -->
  <div id="productModal" class="modal-overlay">
    <div class="modal-content">
      
      <!-- Modal Header -->
      <div class="modal-top-bar">
        <div class="modal-label-text">
          Technical Specifications
        </div>

        <button onclick="closeModal()" class="modal-close-btn" aria-label="Close modal">
          <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <!-- Modal Body -->
      <div class="modal-scroll-body">
        <div class="modal-grid">
          
          <!-- Image side -->
          <div class="modal-image-wrap">
            <img
              id="modalImage"
              src=""
              alt="Product image"
            />
            <div class="modal-image-overlay"></div>
            <div id="modalCategory" class="modal-category">
              Category
            </div>
          </div>
          
          <!-- Content side -->
          <div class="modal-body-content">
            <div class="modal-featured-badge">
              CV LOKA ADI JAYA
            </div>

            <h2 id="modalTitle" class="modal-title-heading">
              Product Name
            </h2>

            <p id="modalDesc" class="modal-desc-paragraph"></p>
            
            <div class="modal-specs-section">
              <h4 class="modal-specs-header">
                Technical Specifications Table
              </h4>

              <ul id="modalSpecs" class="modal-specs-list">
                <!-- Filled via JS -->
              </ul>
            </div>

            <div class="modal-actions">
              <a href="/contact" class="btn modal-action-btn">
                Request Quotation &rarr;
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .products-page {
      background-color: var(--color-offwhite);
      min-height: 100vh;
      padding-top: var(--navbar-height);
    }

  .page-hero-section {
  position: relative;
  overflow: hidden;
  padding: 6rem 0 5rem;
  color: white;
  border-bottom: 1px solid rgba(255,255,255,0.08);
  background-image: url('public/images/hero/bg-kelapa.webp');
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;
  background-color: transparent;
}

/* overlay gelap full, bukan sebelah */
.page-hero-section::before {
  content: '';
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.62);
  pointer-events: none;
  z-index: 0;
}

/* matikan glow/gradient tambahan */
.page-hero-section::after {
  display: none !important;
}

/* pastikan teks ada di atas overlay */
.hero-container,
.products-hero-content {
  position: relative;
  z-index: 1;
}

.products-hero-content .hero-section-title {
  max-width: 1120px;
}

.products-hero-content .hero-section-text {
  max-width: 980px;
}

.hero-section-title {
  font-family: var(--font-heading);
  font-size: clamp(2.5rem, 5vw, 4rem);
  margin-bottom: 1rem;
  color: var(--color-white);
  line-height: 1.1;
  font-weight: 700;
  text-shadow: 0 8px 28px rgba(0, 0, 0, 0.28);
}

.hero-section-text {
  color: rgba(255, 255, 255, 0.82);
  line-height: 1.75;
  font-size: 1.05rem;
  max-width: 680px;
  text-shadow: 0 4px 18px rgba(0, 0, 0, 0.2);
}

    .section-badge-kicker {
      display: inline-block;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--color-accent-warm);
      margin-bottom: 1rem;
    }

    .hero-section-title {
      font-family: var(--font-heading);
      font-size: clamp(2.5rem, 5vw, 4rem);
      margin-bottom: 1rem;
      color: var(--color-white);
      line-height: 1.1;
      font-weight: 700;
    }

    .hero-section-text {
      color: rgba(255, 255, 255, 0.75);
      line-height: 1.75;
      font-size: 1.05rem;
      max-width: 680px;
    }

    .products-toolbar {
      display: flex;
      flex-wrap: wrap;
      gap: 1.25rem;
      align-items: center;
      justify-content: space-between;
      padding-top: 2rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid var(--color-border);
      margin-bottom: 3rem;
    }

    .products-search-wrap {
      position: relative;
      flex-grow: 1;
      max-width: 340px;
    }

    .products-search-input {
      width: 100%;
      padding: 0.75rem 1rem 0.75rem 2.75rem;
      border: 1.5px solid var(--color-border);
      border-radius: var(--radius-full);
      outline: none;
      font-family: var(--font-body);
      font-size: 0.875rem;
      background: var(--color-white);
      color: var(--color-text-primary);
      transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    }

    .products-search-input:focus {
      border-color: var(--color-accent);
      box-shadow: 0 0 0 3px rgba(200, 137, 42, 0.1);
    }

    .products-search-icon {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--color-text-light);
      width: 16px;
      height: 16px;
      pointer-events: none;
    }

    .products-filter-wrap {
      display: flex;
      gap: 0.5rem;
      overflow-x: auto;
      padding-bottom: 2px;
    }

    .filter-btn {
      padding: 0.6rem 1.4rem;
      border-radius: var(--radius-full);
      font-size: 0.82rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
      white-space: nowrap;
      border: 1.5px solid var(--color-border);
      background: var(--color-white);
      color: var(--color-text-secondary);
      font-family: var(--font-body);
    }

    .filter-btn.active {
      background: var(--color-primary);
      color: white;
      border-color: var(--color-primary);
    }

    .filter-btn:hover:not(.active) {
      border-color: var(--color-primary);
      color: var(--color-primary);
    }

    .product-grid-section {
      padding-bottom: 6rem;
    }

    .no-results-box {
      display: none;
      text-align: center;
      padding: 4rem 0;
    }

    .no-results-box h3 {
      font-size: 1.5rem;
      color: var(--color-primary);
      margin-bottom: 0.5rem;
    }

    .no-results-box p {
      color: var(--color-text-secondary);
    }

    .product-layout {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem;
    }

    .product-card {
      display: flex;
      flex-direction: column;
      cursor: pointer;
      border-radius: 32px;
      overflow: hidden;
      background: var(--color-white);
      border: 1px solid var(--color-border);
      box-shadow: 0 4px 24px rgba(0,0,0,0.02);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.4s;
    }

    .product-card:hover {
      transform: scale(1.015) translateY(-4px);
      border-color: var(--color-accent-warm);
      box-shadow: 0 20px 48px rgba(26, 54, 38, 0.08);
    }

    .product-card__image-container {
      position: relative;
      height: 320px;
      overflow: hidden;
      background-color: var(--color-light-gray);
    }

    .product-card__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .product-card:hover .product-card__image {
      transform: scale(1.05);
    }

    .product-card__overlay {
      position: absolute;
      inset: 0;
      background: rgba(26, 54, 38, 0.35);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .product-card:hover .product-card__overlay {
      opacity: 1;
    }

    .product-card__hover-action {
      background: white;
      color: var(--color-primary);
      padding: 0.8rem 1.8rem;
      border-radius: var(--radius-full);
      font-weight: 700;
      font-size: 0.88rem;
      transform: translateY(10px);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .product-card:hover .product-card__hover-action {
      transform: translateY(0);
    }

    .product-card__content {
      padding: 2.5rem;
      display: flex;
      flex-direction: column;
      position: relative;
    }

    .product-card__number {
      font-size: 0.85rem;
      font-weight: 800;
      color: var(--color-accent);
      margin-bottom: 0.75rem;
      display: block;
    }

    .product-card__header-row {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 1.5rem;
      margin-bottom: 1rem;
    }

    .product-card__title {
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--color-primary);
      line-height: 1.2;
    }

    .product-card__badge {
      font-size: 0.65rem;
      font-weight: 700;
      background-color: var(--color-offwhite);
      color: var(--color-accent-dark);
      padding: 0.35rem 0.85rem;
      border-radius: var(--radius-full);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .product-card__desc {
      font-size: 0.95rem;
      color: var(--color-text-secondary);
      line-height: 1.65;
      margin-bottom: 1.75rem;
    }

    .product-card__tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 1.5rem;
    }

    .tag-pill {
      font-size: 0.75rem;
      font-weight: 600;
      border: 1px solid var(--color-border);
      color: var(--color-text-secondary);
      padding: 0.35rem 0.85rem;
      border-radius: var(--radius-full);
      background-color: var(--color-white);
    }

    .product-card__footer {
      border-top: 1px solid var(--color-offwhite);
      padding-top: 1.25rem;
      color: var(--color-primary);
      font-weight: 700;
      font-size: 0.92rem;
      transition: color 0.2s;
    }

    .product-card:hover .product-card__footer {
      color: var(--color-accent);
    }

    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(14, 32, 22, 0.4);
      backdrop-filter: blur(12px);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: var(--z-modal);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      padding: 1.5rem;
    }

    .modal-overlay.active {
      opacity: 1;
      pointer-events: auto;
    }

    .modal-content {
      background: var(--color-white);
      border-radius: 32px;
      max-width: 960px;
      width: 100%;
      max-height: 90vh;
      overflow: hidden;
      box-shadow: 0 32px 80px rgba(0,0,0,0.12);
      border: 1px solid var(--color-border);
      display: flex;
      flex-direction: column;
    }

    .modal-top-bar {
      padding: 1.5rem 2.5rem;
      border-bottom: 1px solid var(--color-border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .modal-label-text {
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--color-text-muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }

    .modal-close-btn {
      background: var(--color-offwhite);
      color: var(--color-text-primary);
      width: 2.2rem;
      height: 2.2rem;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background-color 0.2s;
    }

    .modal-close-btn:hover {
      background: var(--color-light-gray);
    }

    .modal-close-btn svg {
      width: 1.2rem;
      height: 1.2rem;
    }

    .modal-scroll-body {
      overflow-y: auto;
      flex: 1;
    }

    .modal-grid {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
    }

    .modal-image-wrap {
      position: relative;
      height: 100%;
      min-height: 400px;
    }

    .modal-image-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .modal-image-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, transparent, rgba(0,0,0,0.15));
      pointer-events: none;
    }

    .modal-category {
      position: absolute;
      top: 1.5rem;
      left: 1.5rem;
      background: var(--color-primary);
      color: white;
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      padding: 0.35rem 0.95rem;
      border-radius: var(--radius-full);
    }

    .modal-body-content {
      padding: 3rem;
    }

    .modal-featured-badge {
      font-size: 0.75rem;
      font-weight: 700;
      color: var(--color-accent);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
    }

    .modal-title-heading {
      font-family: var(--font-heading);
      font-size: 2.25rem;
      font-weight: 700;
      color: var(--color-primary);
      line-height: 1.15;
      margin-bottom: 1rem;
    }

    .modal-desc-paragraph {
      font-size: 0.95rem;
      color: var(--color-text-secondary);
      line-height: 1.7;
      margin-bottom: 2rem;
    }

    .modal-specs-header {
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--color-primary);
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--color-border);
    }

    .modal-specs-list {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
    }

    .modal-actions {
      margin-top: 2.5rem;
    }

    .modal-action-btn {
      display: inline-flex;
      width: 100%;
      background-color: var(--color-primary);
      color: white;
      justify-content: center;
      padding: 0.9rem;
      border-radius: var(--radius-full);
      font-weight: 600;
      transition: background-color 0.2s;
    }

    .modal-action-btn:hover {
      background-color: var(--color-primary-dark);
      color: white;
    }

    .hide-scrollbar::-webkit-scrollbar {
      display: none;
    }

    .hide-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }

    @media (max-width: 900px) {
      .product-layout {
        grid-template-columns: 1fr;
        gap: 2rem;
      }
      
      .modal-grid {
        grid-template-columns: 1fr;
      }

      .modal-image-wrap {
        min-height: 240px;
        height: 240px;
      }

      .modal-body-content {
        padding: 2rem;
      }
    }
  </style>

  <!-- Pass products data to client side securely -->
  <script is:inline define:vars={{ productsData: products }}>
    window.PRODUCTS_DATA = productsData;
  </script>

  <script is:inline>
    // Filtering and Search Logic
    document.addEventListener('DOMContentLoaded', () => {
      const filterBtns = document.querySelectorAll('.filter-btn');
      const searchInput = document.getElementById('searchInput');
      const cards = document.querySelectorAll('.product-card');
      const noResults = document.getElementById('noResults');
      
      let currentCategory = 'All';
      let currentSearch = '';

      function filterProducts() {
        let visibleCount = 0;
        
        cards.forEach((card) => {
          const cat = card.getAttribute('data-category') || '';
          const searchText = card.getAttribute('data-search') || '';
          
          const matchCategory = currentCategory === 'All' || cat === currentCategory;
          const matchSearch = currentSearch === '' || searchText.includes(currentSearch);
          
          if (matchCategory && matchSearch) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });
        
        if (noResults) {
          noResults.style.display = visibleCount === 0 ? 'block' : 'none';
        }
      }

      filterBtns.forEach((btn) => {
        btn.addEventListener('click', (e) => {
          filterBtns.forEach((b) => {
            b.classList.remove('active');
          });
          
          const target = e.currentTarget;
          target.classList.add('active');
          
          currentCategory = target.getAttribute('data-category') || 'All';
          filterProducts();
        });
      });

      if (searchInput) {
        searchInput.addEventListener('input', (e) => {
          currentSearch = e.target.value.toLowerCase().trim();
          filterProducts();
        });
      }

      filterProducts();
    });

    // Modal Logic
    const modal = document.getElementById('productModal');
    
    window.openModal = function(productId) {
      const product = window.PRODUCTS_DATA.find((p) => p.id === productId);
      if (!product) return;
      
      document.getElementById('modalTitle').textContent = product.name;
      document.getElementById('modalCategory').textContent = product.category;
      document.getElementById('modalDesc').textContent = product.description;

      const modalImage = document.getElementById('modalImage');
      modalImage.src = product.image;
      modalImage.alt = product.name;
      
      const specsContainer = document.getElementById('modalSpecs');
      specsContainer.innerHTML = '';

      Object.entries(product.specifications).forEach(([key, val]) => {
        const li = document.createElement('li');
        li.style.display = 'flex';
        li.style.justifyContent = 'space-between';
        li.style.gap = '1rem';
        li.style.fontSize = '0.875rem';
        li.style.borderBottom = '1px dashed var(--color-border)';
        li.style.paddingBottom = '0.4rem';
        li.innerHTML = `<span style="color: var(--color-text-muted);">${key}</span> <span style="color: var(--color-text-primary); font-weight: 600; text-align: right; max-width: 60%;">${val}</span>`;
        specsContainer.appendChild(li);
      });
      
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    };
    
    window.closeModal = function() {
      modal.classList.remove('active');
      document.body.style.overflow = '';
    };
    
    if (modal) {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
      });
    }
    
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal && modal.classList.contains('active')) {
        closeModal();
      }
    });
  </script>
</MainLayout>