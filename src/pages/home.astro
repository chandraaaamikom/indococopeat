---
import MainLayout from '../layouts/MainLayout.astro';
import { company, statistics, whyChooseUs, businessProcess } from '../data/company';
---

<MainLayout title="Home | INDOCOCOPEAT" currentPage="home">
  <!-- SECTION 1: Hero Section -->
  <section
    class="hero relative flex items-center"
    style="
      min-height: 90vh;
      display: block;
      position: relative;
      overflow: hidden;
      isolation: isolate;
      padding: 7rem 0 4rem;
      background-image:
        linear-gradient(90deg, rgba(27, 67, 50, 0.90) 0%, rgba(27, 67, 50, 0.76) 48%, rgba(92, 39, 8, 0.50) 100%),
        url('/images/hero/bg-fiber.webp');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    "
  >
    <!-- Organic Background Pattern -->
    <div class="organic-bg"></div>
    
    <div class="container relative" style="position: relative; z-index: 10;">
      <div class="grid grid--2 items-center gap-8">
        <!-- Left Column -->
        <div class="hero-content" style="padding-right: 2rem;">
          <div style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.375rem 1rem; background: rgba(255, 255, 255, 0.92); border-radius: var(--radius-full); font-size: 0.75rem; font-weight: 600; color: var(--color-text-secondary); box-shadow: var(--shadow-sm); margin-bottom: 2rem; border: 1px solid rgba(255,255,255,0.45);">
            <span style="width: 8px; height: 8px; background-color: var(--color-primary); border-radius: 50%;"></span>
            PREMIUM EXPORT
            <span style="color: var(--color-border); margin: 0 0.25rem;">|</span>
            Cocopeat & Coconut Fiber
          </div>
          
          <h1 style="font-family: var(--font-heading); font-size: clamp(3rem, 5vw, 4.5rem); color: white; line-height: 1.1; margin-bottom: 1.5rem;">
            Rooted in nature,<br />refined for the world.
          </h1>
          
          <p style="font-size: 1.125rem; color: rgba(255,255,255,0.82); line-height: 1.7; max-width: 560px; margin-bottom: 2.5rem;">
            {company.shortDescription}
          </p>
          
          <div class="flex gap-4 flex-wrap">
            <a href="/product" class="btn btn--white" style="padding: 1rem 2rem; font-size: 1rem; border-radius: var(--radius-full);">
              Explore Products
            </a>
            <a href="/contact" class="btn btn--ghost hero-contact-btn" style="padding: 1rem 2rem; font-size: 1rem; border-radius: var(--radius-full); color: white; border-color: rgba(255,255,255,0.72);">
              Contact Us
            </a>
          </div>
        </div>
        
        <!-- Right Column: Visual Showcase -->
        <div class="hero-visual-wrapper relative hidden md-block" style="height: 560px; position: relative;">
          <div style="position: absolute; inset: 0; background-image: linear-gradient(to top right, rgba(107, 79, 10, 0.72), rgba(45, 106, 79, 0.28)), url('/images/hero/bg-fiber.webp'); background-size: cover; background-position: center; border-radius: 200px 24px 200px 24px; overflow: hidden; box-shadow: var(--shadow-xl);">
            <div style="position: absolute; inset: 0; background: linear-gradient(to top right, rgba(107, 79, 10, 0.45), rgba(27, 67, 50, 0.15)); z-index: 1;"></div>
            
            <!-- Quality Badge -->
            <div style="position: absolute; bottom: 3rem; left: -2rem; background: white; padding: 1.5rem; border-radius: 24px; box-shadow: var(--shadow-lg); z-index: 2; display: flex; align-items: center; gap: 1rem;">
              <div style="width: 48px; height: 48px; background: var(--color-light-gray); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; color: var(--color-primary);">
                🌿
              </div>
              <div>
                <div style="font-family: var(--font-heading); font-size: 1.25rem; color: var(--color-primary); line-height: 1;">
                  100% Organic
                </div>
                <div style="font-size: 0.75rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-top: 0.25rem;">
                  Export Quality
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Stats Bar at bottom of hero -->
    <div class="container relative" style="position: relative; z-index: 20; margin-top: 4rem;">
      <div class="stats-bar" style="background: var(--color-primary); border-radius: var(--radius-xl); padding: 2rem; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 2rem; color: white; box-shadow: var(--shadow-xl);">
        {statistics.map((stat) => (
          <div class="stat-item" style="display: flex; align-items: center; gap: 1rem; flex: 1; min-width: 200px;">
            <div style="font-family: var(--font-heading); font-size: 2.5rem; line-height: 1;">
              <span data-count={stat.value}>{stat.value}</span><span style="color: var(--color-accent-warm);">{stat.suffix}</span>
            </div>
            <div style="font-size: 0.75rem; color: rgba(255,255,255,0.8); text-transform: uppercase; letter-spacing: 0.1em; max-width: 110px;">
              {stat.label}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 2: Why Choose Us -->
  <section class="why-us section section--white" style="padding-top: 8rem;">
    <div class="container">
      <div class="section-header reveal">
        <div class="section-label">WHY CHOOSE US</div>
        <h2 class="section-title" style="font-family: var(--font-heading); color: var(--color-primary);">
          The INDOCOCOPEAT Advantage
        </h2>
        <p class="section-subtitle">
          We combine sustainable practices with professional processing to deliver export-grade coconut fiber products that meet the highest international standards.
        </p>
      </div>
      
      <div class="grid grid--3 reveal">
        {whyChooseUs.map((item) => (
          <div class="card" style="border: 1px solid var(--color-border); box-shadow: none; padding: 2.5rem; text-align: left; background: var(--color-offwhite);">
            <div style="width: 56px; height: 56px; border-radius: 16px; background: white; border: 1px solid var(--color-border); display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 1.5rem; box-shadow: var(--shadow-sm);">
              {item.icon || '✨'}
            </div>
            <h3 style="font-family: var(--font-heading); font-size: 1.25rem; margin-bottom: 0.75rem; color: var(--color-primary);">
              {item.title}
            </h3>
            <p style="font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.7;">
              {item.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION 3: Business Process -->
  <section class="process section section--offwhite">
    <div class="container">
      <div class="section-header reveal">
        <div class="section-label">OUR PROCESS</div>
        <h2 class="section-title" style="font-family: var(--font-heading); color: var(--color-primary);">
          From Coconut Husk to Global Markets
        </h2>
      </div>
      
      <div class="process-wrapper reveal" style="display: flex; justify-content: space-between; align-items: flex-start; position: relative; margin-top: 4rem;">
        {businessProcess.map((step, index) => (
          <div class="process-step" style="display: flex; flex-direction: column; align-items: center; text-align: center; flex: 1; position: relative; z-index: 1; padding: 0 1rem;">
            <div class="process-icon" style="width: 80px; height: 80px; border-radius: 50%; background: white; border: 2px solid var(--color-border); display: flex; align-items: center; justify-content: center; font-size: 2rem; margin-bottom: 1.5rem; position: relative; z-index: 2; box-shadow: var(--shadow-md);">
              {step.icon || '🔄'}
            </div>
            <div style="font-size: 0.75rem; font-weight: 600; color: var(--color-accent-warm); margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.1em;">
              Step 0{index + 1}
            </div>
            <h3 style="font-family: var(--font-heading); font-size: 1.125rem; color: var(--color-primary); margin-bottom: 0.5rem;">
              {step.title}
            </h3>
            <p style="font-size: 0.875rem; color: var(--color-text-secondary); max-width: 180px;">
              {step.description}
            </p>
          </div>
        ))}

        <!-- Desktop Connector Line -->
        <div class="process-line hidden md-block" style="position: absolute; top: 40px; left: 10%; right: 10%; height: 0; border-top: 2px dashed var(--color-border); z-index: 0;"></div>
      </div>
    </div>
  </section>

  <!-- SECTION 4: CTA Section -->
  <section class="cta section relative" style="position: relative; background-color: var(--color-primary); color: white; text-align: center; overflow: hidden; padding: 6rem 0;">
    <div style="position: absolute; inset: 0; opacity: 0.1; background-image: repeating-linear-gradient(45deg, #000 0, #000 1px, transparent 0, transparent 50%); background-size: 20px 20px;"></div>
    
    <div class="container relative reveal" style="position: relative; z-index: 10;">
      <div style="max-width: 700px; margin: 0 auto; background: rgba(255,255,255,0.05); padding: 4rem; border-radius: 32px; border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(10px);">
        <h2 style="font-family: var(--font-heading); font-size: 2.5rem; margin-bottom: 1.5rem; color: white;">
          Ready to Source Premium Cocopeat?
        </h2>
        <p style="font-size: 1.125rem; color: rgba(255,255,255,0.8); line-height: 1.6; margin-bottom: 2.5rem;">
          Explore our complete product catalog with detailed specifications, or get in touch with our export team for custom requirements.
        </p>
        <div class="flex items-center justify-center gap-4 flex-wrap">
          <a href="/product" class="btn" style="background: var(--color-accent-warm); color: white; padding: 1rem 2rem; border-radius: var(--radius-full);">
            View Products
          </a>
          <a href="/contact" class="btn btn--outlined-white" style="border: 2px solid white; color: white; background: transparent; padding: 1rem 2rem; border-radius: var(--radius-full);">
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .hero > .organic-bg {
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      opacity: 0.08;
      background-image: repeating-linear-gradient(
        45deg,
        #ffffff 0,
        #ffffff 1px,
        transparent 0,
        transparent 50%
      );
      background-size: 32px 32px;
    }

    .hero > .organic-bg::before {
      content: none;
    }

    .hidden.md-block {
      display: block;
    }

    .hero-contact-btn:hover {
      background: white !important;
      color: var(--color-primary) !important;
      border-color: white !important;
    }

    @media (max-width: 768px) {
      .hero {
        padding-top: 5rem !important;
        padding-bottom: 3rem !important;
      }

      .hero-content {
        padding-right: 0 !important;
      }

      .hidden.md-block {
        display: none !important;
      }

      .process-wrapper {
        flex-direction: column !important;
        align-items: center !important;
        gap: 3rem;
      }

      .process-step {
        width: 100%;
        max-width: 300px;
      }

      .process-line {
        display: none !important;
      }

      .stat-item {
        width: 100%;
      }

      .cta .container > div {
        padding: 2rem !important;
        border-radius: 24px !important;
      }
    }
  </style>

  <script is:inline>
    // Count-up animation for statistics
    function animateCountUp(el, target, duration = 2000) {
      let start = 0;
      const increment = target / (duration / 16);
      const timer = setInterval(() => {
        start += increment;
        if (start >= target) {
          el.textContent = target.toString();
          clearInterval(timer);
        } else {
          el.textContent = Math.floor(start).toString();
        }
      }, 16);
    }

    document.addEventListener('DOMContentLoaded', () => {
      const statsObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const counters = entry.target.querySelectorAll('[data-count]');
            counters.forEach(counter => {
              const target = parseInt(counter.getAttribute('data-count') || '0', 10);
              animateCountUp(counter, target);
            });
            statsObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.3 });

      const statsBar = document.querySelector('.stats-bar');
      if (statsBar) statsObserver.observe(statsBar);
    });
  </script>
</MainLayout>