---
import MainLayout from '../layouts/MainLayout.astro';
import { products, productCategories } from '../data/products';
---

<MainLayout title="Product Catalog | INDOCOCOPEAT" currentPage="product">
  <div class="page-content" style="background-color: var(--color-offwhite); min-height: 100vh;">
    
    <!-- Header -->
    <div class="container" style="padding-top: 4rem; padding-bottom: 2rem;">
      <div style="max-width: 600px;">
        <h1 style="font-family: var(--font-heading); font-size: 3rem; margin-bottom: 1rem; color: var(--color-primary);">Product Catalog</h1>
        <p style="color: var(--color-text-secondary); line-height: 1.6; font-size: 1.125rem;">
          High quality coconut coir products from Indonesia, crafted for global horticulture and industrial needs.
        </p>
      </div>
    </div>

    <!-- Toolbar: Search & Filter -->
    <div class="container" style="margin-bottom: 3rem;">
      <div style="display: flex; flex-wrap: wrap; gap: 1.5rem; align-items: center; justify-content: space-between; padding-bottom: 1rem; border-bottom: 1px solid var(--color-border);">
        
        <!-- Search -->
        <div style="position: relative; flex-grow: 1; max-width: 320px;">
          <input 
            type="text" 
            id="searchInput"
            placeholder="Search product..." 
            style="width: 100%; padding: 0.75rem 1rem 0.75rem 2.5rem; border: 1px solid var(--color-border); border-radius: var(--radius-full); outline: none; font-family: inherit; font-size: 0.875rem; background: white;"
          />
          <svg style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--color-text-light); width: 16px; height: 16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>

        <!-- Filter -->
        <div style="display: flex; gap: 0.5rem; overflow-x: auto; padding-bottom: 4px;" class="hide-scrollbar">
          {productCategories.map((category, index) => (
            <button 
              class={`filter-btn ${index === 0 ? 'active' : ''}`}
              data-category={category}
              style={`padding: 0.5rem 1.25rem; border-radius: var(--radius-full); font-size: 0.875rem; font-weight: 500; cursor: pointer; transition: all 0.2s; white-space: nowrap; ${index === 0 ? 'background: var(--color-primary); color: white; border: 1px solid var(--color-primary);' : 'background: white; color: var(--color-text-secondary); border: 1px solid var(--color-border);'}`}
            >
              {category}
            </button>
          ))}
        </div>
        
      </div>
    </div>

    <!-- Product Grid -->
    <div class="container section" style="padding-top: 0; padding-bottom: 6rem;">
      <div id="noResults" style="display: none; text-align: center; padding: 4rem 0;">
        <div style="font-size: 4rem; margin-bottom: 1rem;">🔍</div>
        <h3 style="font-family: var(--font-heading); font-size: 1.5rem; color: var(--color-primary); margin-bottom: 0.5rem;">No products found</h3>
        <p style="color: var(--color-text-secondary);">Try adjusting your search or category filter.</p>
      </div>

      <div class="product-layout" id="productGrid">
        {products.map((product, index) => (
          <div 
            class={`product-card ${index === 0 ? 'featured-card' : 'standard-card'}`} 
            data-category={product.category}
            data-name={product.name.toLowerCase()}
            onclick={`openModal('${product.id}')`}
          >
            {index === 0 ? (
              // FEATURED CARD LAYOUT
              <div class="featured-inner">
                <div class="featured-content">
                  <div class="badge" style="background: rgba(255,255,255,0.1); color: var(--color-accent-warm); border: 1px solid rgba(255,255,255,0.2); margin-bottom: 1rem; display: inline-flex; align-items: center; gap: 0.5rem;">
                    <span>★</span> FEATURED
                  </div>
                  <h2 style="font-family: var(--font-heading); font-size: 2.5rem; color: white; margin-bottom: 1rem;">{product.name}</h2>
                  <p style="color: rgba(255,255,255,0.8); line-height: 1.6; margin-bottom: 2rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                    {product.description}
                  </p>
                  
                  <ul style="list-style: none; padding: 0; margin: 0 0 2rem 0; display: flex; flex-direction: column; gap: 0.75rem;">
                    {product.features.slice(0, 3).map(feat => (
                      <li style="display: flex; align-items: flex-start; gap: 0.75rem; color: white; font-size: 0.875rem;">
                        <svg style="width: 18px; height: 18px; color: var(--color-accent-warm); flex-shrink: 0;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        {feat}
                      </li>
                    ))}
                  </ul>
                  
                  <div style="margin-top: auto;">
                    <span class="btn" style="background: var(--color-accent-warm); color: white; border-radius: var(--radius-full); padding: 0.75rem 1.5rem;">
                      View Details &rarr;
                    </span>
                  </div>
                </div>
                <div class="featured-image">
                  <div style="position: absolute; inset: 0; background-color: var(--color-secondary); opacity: 0.5; mix-blend-mode: multiply;"></div>
                  <span style="font-size: 8rem; position: relative; z-index: 2; opacity: 0.5;">📦</span>
                </div>
              </div>
            ) : (
              // STANDARD CARD LAYOUT (Horizontal)
              <div class="standard-inner">
                <div class="standard-image">
                  <span style="font-size: 4rem; color: #D1CFC7;">📦</span>
                </div>
                <div class="standard-content">
                  <h3 style="font-family: var(--font-heading); font-size: 1.5rem; color: var(--color-primary); margin-bottom: 0.5rem;">{product.name}</h3>
                  <p style="font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.6; margin-bottom: 1rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                    {product.description}
                  </p>
                  <div style="margin-top: auto; color: var(--color-accent-warm); font-size: 0.875rem; font-weight: 600; display: flex; align-items: center; gap: 0.25rem;">
                    View Product &rarr;
                  </div>
                </div>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Modal -->
  <div id="productModal" class="modal-overlay">
    <div class="modal-content" style="display: flex; flex-direction: column; max-width: 900px; width: 100%; max-height: 90vh; overflow: hidden; border-radius: 24px;">
      
      <!-- Modal Header -->
      <div style="padding: 1.5rem 2rem; border-bottom: 1px solid var(--color-border); display: flex; justify-content: space-between; align-items: center; background: white; z-index: 10;">
        <div style="font-size: 0.75rem; font-weight: 600; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.1em;">Product Details</div>
        <button onclick="closeModal()" style="background: var(--color-light-gray); border: none; cursor: pointer; padding: 0.5rem; color: var(--color-text-secondary); display: flex; align-items: center; justify-content: center; border-radius: 50%; transition: background 0.2s;">
          <svg style="width: 20px; height: 20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>

      <!-- Modal Body -->
      <div style="overflow-y: auto; padding: 0; background: white;">
        <div class="grid modal-grid" style="gap: 0;">
          
          <!-- Image side -->
          <div style="background-color: var(--color-light-gray); display: flex; align-items: center; justify-content: center; min-height: 300px; position: relative;">
            <span style="font-size: 8rem; color: var(--color-border);">📦</span>
            <div id="modalCategory" style="position: absolute; top: 1.5rem; left: 1.5rem; padding: 0.375rem 1rem; background: white; color: var(--color-primary); font-size: 0.75rem; font-weight: 600; text-transform: uppercase; border-radius: var(--radius-full); box-shadow: var(--shadow-sm);">Category</div>
          </div>
          
          <!-- Content side -->
          <div style="padding: 2.5rem;">
            <div style="font-size: 0.75rem; font-weight: 600; color: var(--color-accent-warm); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.5rem;">FEATURED PRODUCT</div>
            <h2 id="modalTitle" style="font-family: var(--font-heading); font-size: 2.25rem; color: var(--color-primary); margin-bottom: 1rem; line-height: 1.1;">Product Name</h2>
            <p id="modalDesc" style="font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.7; margin-bottom: 2rem;"></p>
            
            <div style="margin-bottom: 2rem;">
              <h4 style="font-size: 1rem; font-weight: 600; color: var(--color-primary); margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--color-border);">Technical Specification</h4>
              <ul id="modalSpecs" style="list-style: none; padding: 0; margin: 0; display: grid; gap: 0.75rem;">
                <!-- Filled via JS -->
              </ul>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 2.5rem;">
              <a href="/contact" class="btn" style="flex: 1; background: var(--color-accent-warm); color: white; border-radius: var(--radius-full); justify-content: center;">Request Quotation &rarr;</a>
              <button class="btn btn--ghost" style="border-radius: var(--radius-full); padding: 0 1.5rem;" onclick="alert('Datasheet PDF download initiated.')">Download Datasheet</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .product-layout {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 1.5rem;
    }

    .product-card {
      cursor: pointer;
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      border-radius: 24px;
      overflow: hidden;
    }

    .product-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-xl);
    }

    .featured-card {
      grid-column: span 7;
      grid-row: span 2;
      background-color: var(--color-primary);
    }

    .featured-inner {
      display: flex;
      height: 100%;
      min-height: 500px;
    }

    .featured-content {
      flex: 1;
      padding: 3rem;
      display: flex;
      flex-direction: column;
    }

    .featured-image {
      flex: 0.8;
      background-color: var(--color-secondary-light);
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
      border-top-left-radius: 60px;
      border-bottom-left-radius: 60px;
    }

    .standard-card {
      grid-column: span 5;
      background: white;
      border: 1px solid var(--color-border);
      box-shadow: var(--shadow-sm);
    }

    .standard-inner {
      display: flex;
      height: 100%;
      min-height: 180px;
    }

    .standard-image {
      width: 160px;
      background-color: var(--color-light-gray);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .standard-content {
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    .filter-btn:hover:not(.active) {
      background: var(--color-light-gray) !important;
    }

    .hide-scrollbar::-webkit-scrollbar {
      display: none;
    }
    .hide-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    
    .modal-grid {
      grid-template-columns: 1fr 1.2fr;
    }

    @media (max-width: 1024px) {
      .product-layout {
        display: flex;
        flex-direction: column;
      }
      .featured-inner {
        flex-direction: column-reverse;
        min-height: auto;
      }
      .featured-image {
        min-height: 250px;
        border-radius: 0;
      }
      .standard-inner {
        flex-direction: column;
      }
      .standard-image {
        width: 100%;
        height: 200px;
      }
    }
    
    @media (max-width: 768px) {
      .modal-grid {
        grid-template-columns: 1fr;
      }
      #productModal .modal-content {
        max-height: 95vh;
        border-radius: 16px;
      }
    }
  </style>

  <!-- Pass products data to client side securely -->
  <script is:inline define:vars={{ productsData: products }}>
    window.PRODUCTS_DATA = productsData;
  </script>

  <script is:inline>
    // Filtering and Search Logic
    document.addEventListener('DOMContentLoaded', () => {
      const filterBtns = document.querySelectorAll('.filter-btn');
      const searchInput = document.getElementById('searchInput');
      const cards = document.querySelectorAll('.product-card');
      const noResults = document.getElementById('noResults');
      
      let currentCategory = 'All';
      let currentSearch = '';

      function filterProducts() {
        let visibleCount = 0;
        
        cards.forEach(card => {
          const cat = card.getAttribute('data-category');
          const name = card.getAttribute('data-name');
          
          const matchCategory = currentCategory === 'All' || cat === currentCategory;
          const matchSearch = currentSearch === '' || name.includes(currentSearch);
          
          if (matchCategory && matchSearch) {
            card.style.display = 'block';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });
        
        noResults.style.display = visibleCount === 0 ? 'block' : 'none';
      }

      filterBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          filterBtns.forEach(b => {
            b.classList.remove('active');
            b.style.background = 'white';
            b.style.color = 'var(--color-text-secondary)';
            b.style.border = '1px solid var(--color-border)';
          });
          
          const target = e.currentTarget;
          target.classList.add('active');
          target.style.background = 'var(--color-primary)';
          target.style.color = 'white';
          target.style.border = '1px solid var(--color-primary)';
          
          currentCategory = target.getAttribute('data-category');
          filterProducts();
        });
      });

      if (searchInput) {
        searchInput.addEventListener('input', (e) => {
          currentSearch = e.target.value.toLowerCase().trim();
          filterProducts();
        });
      }
    });

    // Modal Logic
    const modal = document.getElementById('productModal');
    
    window.openModal = function(productId) {
      const product = window.PRODUCTS_DATA.find(p => p.id === productId);
      if (!product) return;
      
      document.getElementById('modalTitle').textContent = product.name;
      document.getElementById('modalCategory').textContent = product.category;
      document.getElementById('modalDesc').textContent = product.description;
      
      // Specs
      const specsContainer = document.getElementById('modalSpecs');
      specsContainer.innerHTML = '';
      Object.entries(product.specifications).forEach(([key, val]) => {
        const li = document.createElement('li');
        li.style.display = 'flex';
        li.style.justifyContent = 'space-between';
        li.style.fontSize = '0.875rem';
        li.style.borderBottom = '1px dashed var(--color-border)';
        li.style.paddingBottom = '0.25rem';
        li.innerHTML = `<span style="color: var(--color-text-muted);">${key}</span> <span style="color: var(--color-text-primary); font-weight: 500; text-align: right; max-width: 60%;">${val}</span>`;
        specsContainer.appendChild(li);
      });
      
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    };
    
    window.closeModal = function() {
      modal.classList.remove('active');
      document.body.style.overflow = '';
    };
    
    // Close on backdrop click
    if(modal) {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
      });
    }
    
    // Close on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal && modal.classList.contains('active')) {
        closeModal();
      }
    });
  </script>
</MainLayout>
