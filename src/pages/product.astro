---
import MainLayout from '../layouts/MainLayout.astro';
import { products, productCategories } from '../data/products';
---

<MainLayout title="Products | INDOCOCOPEAT" currentPage="product">
  <div class="page-content" style="background-color: #FAFAF5; min-height: 100vh;">
    
    <!-- Header -->
    <div style="background-color: #1B4332; color: white; padding: 4rem 0;">
      <div class="container text-center">
        <h1 style="font-family: 'DM Serif Display', serif; font-size: 3rem; margin-bottom: 1rem;">Our Premium Products</h1>
        <p style="color: rgba(255,255,255,0.8); max-width: 600px; margin: 0 auto; line-height: 1.6;">
          Explore our range of export-grade cocopeat and coconut fiber products. Processed to meet international standards for sustainable agriculture.
        </p>
      </div>
    </div>

    <!-- Toolbar: Search & Filter -->
    <div class="container" style="margin-top: -1.5rem; margin-bottom: 3rem; position: relative; z-index: 10;">
      <div style="background: white; border-radius: 12px; padding: 1.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.08); display: flex; flex-wrap: wrap; gap: 1.5rem; align-items: center; justify-content: space-between;">
        
        <!-- Filter -->
        <div style="display: flex; gap: 0.5rem; overflow-x: auto; padding-bottom: 4px;">
          {productCategories.map((category, index) => (
            <button 
              class={`filter-btn ${index === 0 ? 'active' : ''}`}
              data-category={category}
              style={`padding: 0.5rem 1.25rem; border-radius: 99px; font-size: 0.875rem; font-weight: 500; cursor: pointer; transition: all 0.2s; white-space: nowrap; ${index === 0 ? 'background: #2D6A4F; color: white; border: 1px solid #2D6A4F;' : 'background: white; color: #4A4A4A; border: 1px solid #E2E0D8;'}`}
            >
              {category}
            </button>
          ))}
        </div>

        <!-- Search -->
        <div style="position: relative; flex-grow: 1; max-width: 320px;">
          <input 
            type="text" 
            id="searchInput"
            placeholder="Search products..." 
            style="width: 100%; padding: 0.75rem 1rem 0.75rem 2.5rem; border: 1px solid #E2E0D8; border-radius: 8px; outline: none; font-family: inherit; font-size: 0.875rem;"
          />
          <svg style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: #9A9A9A; width: 16px; height: 16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
        </div>
        
      </div>
    </div>

    <!-- Product Grid -->
    <div class="container section" style="padding-top: 0;">
      <div id="noResults" style="display: none; text-align: center; padding: 4rem 0;">
        <h3 style="font-family: 'DM Serif Display', serif; font-size: 1.5rem; color: #1A1A1A; margin-bottom: 0.5rem;">No products found</h3>
        <p style="color: #7A7A7A;">Try adjusting your search or category filter.</p>
      </div>

      <div class="grid grid--2" id="productGrid">
        {products.map((product) => (
          <div 
            class="product-card" 
            data-category={product.category}
            data-name={product.name.toLowerCase()}
            style="background: white; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.05); transition: transform 0.3s, box-shadow 0.3s; cursor: pointer; display: flex; flex-direction: column; height: 100%;"
            onclick={`openModal('${product.id}')`}
          >
            <!-- Image placeholder since we don't have real images -->
            <div style="height: 240px; background-color: #E2E0D8; position: relative; display: flex; align-items: center; justify-content: center; overflow: hidden;">
              <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, transparent, rgba(0,0,0,0.4)); z-index: 1;"></div>
              <div class="badge" style="position: absolute; top: 1rem; right: 1rem; z-index: 2; background: white; color: #2D6A4F; font-weight: 600; padding: 0.25rem 0.75rem; border-radius: 99px; font-size: 0.75rem; text-transform: uppercase;">
                {product.category}
              </div>
              <span style="font-size: 4rem; color: #9A9A9A; z-index: 0;">📦</span>
            </div>
            
            <div style="padding: 1.5rem; flex-grow: 1; display: flex; flex-direction: column;">
              <h3 style="font-family: 'DM Serif Display', serif; font-size: 1.5rem; margin-bottom: 0.75rem; color: #1A1A1A;">{product.name}</h3>
              <p style="font-size: 0.875rem; color: #7A7A7A; line-height: 1.6; margin-bottom: 1.5rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                {product.description}
              </p>
              
              <div style="margin-top: auto; display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #F5F5F0; padding-top: 1rem;">
                <span style="font-size: 0.875rem; font-weight: 500; color: #2D6A4F;">View Details</span>
                <svg style="width: 20px; height: 20px; color: #2D6A4F;" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Modal -->
  <div id="productModal" class="modal-overlay">
    <div class="modal-content" style="display: flex; flex-direction: column; max-width: 900px; width: 100%; max-height: 90vh; overflow: hidden;">
      
      <!-- Modal Header -->
      <div style="padding: 1.5rem; border-bottom: 1px solid #E2E0D8; display: flex; justify-content: space-between; align-items: center; background: white; z-index: 10;">
        <h2 id="modalTitle" style="font-family: 'DM Serif Display', serif; font-size: 1.75rem; color: #1A1A1A; margin: 0;">Product Details</h2>
        <button onclick="closeModal()" style="background: none; border: none; cursor: pointer; padding: 0.5rem; color: #7A7A7A; display: flex; align-items: center; justify-content: center; border-radius: 50%; transition: background 0.2s;">
          <svg style="width: 24px; height: 24px;" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>

      <!-- Modal Body -->
      <div style="overflow-y: auto; padding: 0;">
        <div class="grid grid--2" style="gap: 0;">
          
          <!-- Image side -->
          <div style="background-color: #F5F5F0; display: flex; align-items: center; justify-content: center; padding: 3rem; min-height: 300px;">
            <span style="font-size: 6rem; color: #D1CFC7;">📦</span>
          </div>
          
          <!-- Content side -->
          <div style="padding: 2rem;">
            <div id="modalCategory" style="display: inline-block; padding: 0.25rem 0.75rem; background: rgba(45,106,79,0.1); color: #2D6A4F; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; border-radius: 99px; margin-bottom: 1rem;">Category</div>
            
            <p id="modalDesc" style="font-size: 0.9375rem; color: #4A4A4A; line-height: 1.7; margin-bottom: 2rem;"></p>
            
            <div style="margin-bottom: 2rem;">
              <h4 style="font-size: 1rem; font-weight: 600; color: #1A1A1A; margin-bottom: 1rem; border-bottom: 1px solid #E2E0D8; padding-bottom: 0.5rem;">Technical Specifications</h4>
              <ul id="modalSpecs" style="list-style: none; padding: 0; margin: 0; display: grid; gap: 0.75rem;">
                <!-- Filled via JS -->
              </ul>
            </div>

            <div>
              <h4 style="font-size: 1rem; font-weight: 600; color: #1A1A1A; margin-bottom: 1rem; border-bottom: 1px solid #E2E0D8; padding-bottom: 0.5rem;">Key Features</h4>
              <ul id="modalFeatures" style="list-style: none; padding: 0; margin: 0; display: grid; gap: 0.5rem;">
                <!-- Filled via JS -->
              </ul>
            </div>
            
            <div style="margin-top: 2.5rem;">
              <a href="/contact" class="btn btn--primary" style="width: 100%; text-align: center;">Inquire About This Product</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .product-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 24px rgba(0,0,0,0.1) !important;
    }
    .filter-btn:hover:not(.active) {
      background: #F5F5F0 !important;
    }
    
    @media (max-width: 768px) {
      #productModal .grid--2 {
        grid-template-columns: 1fr;
      }
      #productModal .modal-content {
        max-height: 95vh;
        border-radius: 12px;
      }
    }
  </style>

  <!-- Pass products data to client side securely -->
  <script is:inline define:vars={{ productsData: products }}>
    window.PRODUCTS_DATA = productsData;
  </script>

  <script is:inline>
    // Filtering and Search Logic
    document.addEventListener('DOMContentLoaded', () => {
      const filterBtns = document.querySelectorAll('.filter-btn');
      const searchInput = document.getElementById('searchInput');
      const cards = document.querySelectorAll('.product-card');
      const noResults = document.getElementById('noResults');
      
      let currentCategory = 'All';
      let currentSearch = '';

      function filterProducts() {
        let visibleCount = 0;
        
        cards.forEach(card => {
          const cat = card.getAttribute('data-category');
          const name = card.getAttribute('data-name');
          
          const matchCategory = currentCategory === 'All' || cat === currentCategory;
          const matchSearch = currentSearch === '' || name.includes(currentSearch);
          
          if (matchCategory && matchSearch) {
            card.style.display = 'flex';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });
        
        noResults.style.display = visibleCount === 0 ? 'block' : 'none';
      }

      filterBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          filterBtns.forEach(b => {
            b.classList.remove('active');
            b.style.background = 'white';
            b.style.color = '#4A4A4A';
            b.style.border = '1px solid #E2E0D8';
          });
          
          const target = e.currentTarget;
          target.classList.add('active');
          target.style.background = '#2D6A4F';
          target.style.color = 'white';
          target.style.border = '1px solid #2D6A4F';
          
          currentCategory = target.getAttribute('data-category');
          filterProducts();
        });
      });

      if (searchInput) {
        searchInput.addEventListener('input', (e) => {
          currentSearch = e.target.value.toLowerCase().trim();
          filterProducts();
        });
      }
    });

    // Modal Logic
    const modal = document.getElementById('productModal');
    
    window.openModal = function(productId) {
      const product = window.PRODUCTS_DATA.find(p => p.id === productId);
      if (!product) return;
      
      document.getElementById('modalTitle').textContent = product.name;
      document.getElementById('modalCategory').textContent = product.category;
      document.getElementById('modalDesc').textContent = product.description;
      
      // Specs
      const specsContainer = document.getElementById('modalSpecs');
      specsContainer.innerHTML = '';
      Object.entries(product.specifications).forEach(([key, val]) => {
        const li = document.createElement('li');
        li.style.display = 'flex';
        li.style.justifyContent = 'space-between';
        li.style.fontSize = '0.875rem';
        li.innerHTML = `<span style="color: #7A7A7A;">${key}</span> <span style="color: #1A1A1A; font-weight: 500; text-align: right; max-width: 60%;">${val}</span>`;
        specsContainer.appendChild(li);
      });
      
      // Features
      const featuresContainer = document.getElementById('modalFeatures');
      featuresContainer.innerHTML = '';
      product.features.forEach(feat => {
        const li = document.createElement('li');
        li.style.fontSize = '0.875rem';
        li.style.color = '#4A4A4A';
        li.style.display = 'flex';
        li.style.alignItems = 'flex-start';
        li.style.gap = '0.5rem';
        li.innerHTML = `<svg style="width: 16px; height: 16px; color: #2D6A4F; flex-shrink: 0; margin-top: 2px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> ${feat}`;
        featuresContainer.appendChild(li);
      });
      
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    };
    
    window.closeModal = function() {
      modal.classList.remove('active');
      document.body.style.overflow = '';
    };
    
    // Close on backdrop click
    if(modal) {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
      });
    }
    
    // Close on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal && modal.classList.contains('active')) {
        closeModal();
      }
    });
  </script>
</MainLayout>
