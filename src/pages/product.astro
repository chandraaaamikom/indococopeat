---
import MainLayout from '../layouts/MainLayout.astro';
import { products, productCategories } from '../data/products';
---

<MainLayout title="Product Catalog | INDOCOCOPEAT" currentPage="product">
  <div class="page-content" style="background-color: var(--color-offwhite); min-height: 100vh;">
    
    <!-- Header -->
    <div class="container" style="padding-top: 4rem; padding-bottom: 2rem;">
      <div style="max-width: 600px;">
        <h1 style="font-family: var(--font-heading); font-size: 3rem; margin-bottom: 1rem; color: var(--color-primary);">
          Product Catalog
        </h1>
        <p style="color: var(--color-text-secondary); line-height: 1.6; font-size: 1.125rem;">
          High quality coconut coir products from Indonesia, crafted for global horticulture and industrial needs.
        </p>
      </div>
    </div>

    <!-- Toolbar: Search & Filter -->
    <div class="container" style="margin-bottom: 3rem;">
      <div style="display: flex; flex-wrap: wrap; gap: 1.5rem; align-items: center; justify-content: space-between; padding-bottom: 1rem; border-bottom: 1px solid var(--color-border);">
        
        <!-- Search -->
        <div style="position: relative; flex-grow: 1; max-width: 320px;">
          <input 
            type="text" 
            id="searchInput"
            placeholder="Search product..." 
            style="width: 100%; padding: 0.75rem 1rem 0.75rem 2.5rem; border: 1px solid var(--color-border); border-radius: var(--radius-full); outline: none; font-family: inherit; font-size: 0.875rem; background: white;"
          />
          <svg style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--color-text-light); width: 16px; height: 16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </div>

        <!-- Filter -->
        <div style="display: flex; gap: 0.5rem; overflow-x: auto; padding-bottom: 4px;" class="hide-scrollbar">
          {productCategories.map((category, index) => (
            <button 
              class={`filter-btn ${index === 0 ? 'active' : ''}`}
              data-category={category}
              style={`padding: 0.5rem 1.25rem; border-radius: var(--radius-full); font-size: 0.875rem; font-weight: 500; cursor: pointer; transition: all 0.2s; white-space: nowrap; ${index === 0 ? 'background: var(--color-primary); color: white; border: 1px solid var(--color-primary);' : 'background: white; color: var(--color-text-secondary); border: 1px solid var(--color-border);'}`}
            >
              {category}
            </button>
          ))}
        </div>
        
      </div>
    </div>

    <!-- Product Grid -->
    <div class="container section" style="padding-top: 0; padding-bottom: 6rem;">
      <div id="noResults" style="display: none; text-align: center; padding: 4rem 0;">
        <h3 style="font-family: var(--font-heading); font-size: 1.5rem; color: var(--color-primary); margin-bottom: 0.5rem;">
          No products found
        </h3>
        <p style="color: var(--color-text-secondary);">
          Try adjusting your search or category filter.
        </p>
      </div>

      <div class="product-layout" id="productGrid">
        {products.map((product) => (
          <article 
            class="product-card" 
            data-category={product.category}
            data-name={product.name.toLowerCase()}
            role="button"
            tabindex="0"
            onclick={`openModal('${product.id}')`}
            onkeydown={`if(event.key === 'Enter' || event.key === ' ') { event.preventDefault(); openModal('${product.id}'); }`}
          >
            <div class="product-card__image">
              <img
                src={product.image}
                alt={product.name}
                loading="lazy"
              />
            </div>

            <div class="product-card__body">
              <div class="product-card__category">{product.category}</div>

              <h2 class="product-card__title">
                {product.name}
              </h2>

              <p class="product-card__description">
                {product.description}
              </p>

              <ul class="product-card__features" aria-label={`${product.name} highlights`}>
                {product.features.slice(0, 2).map((feat) => (
                  <li>{feat}</li>
                ))}
              </ul>

              <div class="product-card__footer">
                <span>View Product &rarr;</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>

  <!-- Modal -->
  <div id="productModal" class="modal-overlay">
    <div class="modal-content" style="display: flex; flex-direction: column; max-width: 900px; width: 100%; max-height: 90vh; overflow: hidden; border-radius: 24px;">
      
      <!-- Modal Header -->
      <div style="padding: 1.5rem 2rem; border-bottom: 1px solid var(--color-border); display: flex; justify-content: space-between; align-items: center; background: white; z-index: 10;">
        <div style="font-size: 0.75rem; font-weight: 600; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.1em;">
          Product Details
        </div>

        <button onclick="closeModal()" style="background: var(--color-light-gray); border: none; cursor: pointer; padding: 0.5rem; color: var(--color-text-secondary); display: flex; align-items: center; justify-content: center; border-radius: 50%; transition: background 0.2s;">
          <svg style="width: 20px; height: 20px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <!-- Modal Body -->
      <div style="overflow-y: auto; padding: 0; background: white;">
        <div class="grid modal-grid" style="gap: 0;">
          
          <!-- Image side -->
          <div class="modal-image-wrap">
            <img
              id="modalImage"
              src=""
              alt="Product image"
            />
            <div class="modal-image-overlay"></div>
            <div id="modalCategory" class="modal-category">
              Category
            </div>
          </div>
          
          <!-- Content side -->
          <div style="padding: 2.5rem;">
            <div style="font-size: 0.75rem; font-weight: 600; color: var(--color-accent-warm); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.5rem;">
              FEATURED PRODUCT
            </div>

            <h2 id="modalTitle" style="font-family: var(--font-heading); font-size: 2.25rem; color: var(--color-primary); margin-bottom: 1rem; line-height: 1.1;">
              Product Name
            </h2>

            <p id="modalDesc" style="font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.7; margin-bottom: 2rem;"></p>
            
            <div style="margin-bottom: 2rem;">
              <h4 style="font-size: 1rem; font-weight: 600; color: var(--color-primary); margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--color-border);">
                Technical Specification
              </h4>

              <ul id="modalSpecs" style="list-style: none; padding: 0; margin: 0; display: grid; gap: 0.75rem;">
                <!-- Filled via JS -->
              </ul>
            </div>

            <div style="display: flex; gap: 1rem; margin-top: 2.5rem;">
              <a href="/contact" class="btn" style="flex: 1; background: var(--color-accent-warm); color: white; border-radius: var(--radius-full); justify-content: center;">
                Request Quotation &rarr;
              </a>

              <button class="btn btn--ghost" style="border-radius: var(--radius-full); padding: 0 1.5rem;" onclick="alert('Datasheet PDF download initiated.')">
                Download Datasheet
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .product-layout {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1.25rem;
      align-items: stretch;
    }

    .product-card {
      min-width: 0;
      min-height: 460px;
      display: flex;
      flex-direction: column;
      cursor: pointer;
      border-radius: 20px;
      overflow: hidden;
      background: white;
      border: 1px solid var(--color-border);
      box-shadow: 0 12px 34px rgba(var(--color-primary-rgb), 0.07);
      transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
    }

    .product-card:hover,
    .product-card:focus-visible {
      transform: translateY(-4px);
      border-color: rgba(var(--color-primary-rgb), 0.28);
      box-shadow: 0 20px 48px rgba(var(--color-primary-rgb), 0.12);
      outline: none;
    }

    .product-card:active {
      transform: translateY(-1px);
    }

    .product-card__image {
      height: 220px;
      background-color: var(--color-light-gray);
      overflow: hidden;
      position: relative;
      flex-shrink: 0;
    }

    .product-card__image::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(26, 54, 38, 0.02), rgba(26, 54, 38, 0.2));
      pointer-events: none;
    }

    .product-card__image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.4s ease;
    }

    .product-card:hover .product-card__image img,
    .product-card:focus-visible .product-card__image img {
      transform: scale(1.04);
    }

    .product-card__body {
      min-height: 240px;
      padding: 1.35rem;
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    .product-card__category {
      width: fit-content;
      margin-bottom: 0.85rem;
      padding: 0.3rem 0.75rem;
      border-radius: var(--radius-full);
      background: rgba(var(--color-primary-rgb), 0.08);
      color: var(--color-primary);
      font-size: 0.7rem;
      font-weight: 700;
      line-height: 1;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }

    .product-card__title {
      min-height: 3.3rem;
      margin-bottom: 0.65rem;
      font-family: var(--font-heading);
      font-size: clamp(1.35rem, 1.8vw, 1.75rem);
      line-height: 1.05;
      color: var(--color-primary);
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .product-card__description {
      min-height: 4.2rem;
      margin: 0 0 1rem;
      color: var(--color-text-secondary);
      font-size: 0.9rem;
      line-height: 1.55;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .product-card__features {
      min-height: 3.2rem;
      display: grid;
      gap: 0.4rem;
      margin: 0 0 1.25rem;
      color: var(--color-text-muted);
      font-size: 0.78rem;
      line-height: 1.35;
    }

    .product-card__features li {
      display: -webkit-box;
      -webkit-line-clamp: 1;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .product-card__footer {
      margin-top: auto;
      padding-top: 1rem;
      border-top: 1px solid var(--color-border);
      color: var(--color-secondary-light);
      font-size: 0.875rem;
      font-weight: 700;
    }

    .filter-btn:hover:not(.active) {
      background: var(--color-light-gray) !important;
    }

    .hide-scrollbar::-webkit-scrollbar {
      display: none;
    }

    .hide-scrollbar {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
    
    .modal-grid {
      grid-template-columns: 1fr 1.2fr;
    }

    .modal-image-wrap {
      background-color: var(--color-light-gray);
      min-height: 360px;
      position: relative;
      overflow: hidden;
    }

    .modal-image-wrap img {
      width: 100%;
      height: 100%;
      min-height: 360px;
      object-fit: cover;
      display: block;
    }

    .modal-image-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, rgba(0,0,0,0.08), rgba(0,0,0,0.28));
      z-index: 1;
      pointer-events: none;
    }

    .modal-category {
      position: absolute;
      top: 1.5rem;
      left: 1.5rem;
      z-index: 2;
      padding: 0.375rem 1rem;
      background: white;
      color: var(--color-primary);
      font-size: 0.75rem;
      font-weight: 600;
      text-transform: uppercase;
      border-radius: var(--radius-full);
      box-shadow: var(--shadow-sm);
    }

    @media (max-width: 1100px) {
      .product-layout {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 640px) {
      .product-layout {
        grid-template-columns: 1fr;
      }

      .product-card {
        min-height: 0;
      }

      .product-card__image {
        height: 240px;
      }
    }
    
    @media (max-width: 768px) {
      .modal-grid {
        grid-template-columns: 1fr;
      }

      #productModal .modal-content {
        max-height: 95vh;
        border-radius: 16px;
      }

      .modal-image-wrap,
      .modal-image-wrap img {
        min-height: 240px;
      }

      .modal-content .btn {
        font-size: 0.75rem;
      }
    }
  </style>

  <!-- Pass products data to client side securely -->
  <script is:inline define:vars={{ productsData: products }}>
    window.PRODUCTS_DATA = productsData;
  </script>

  <script is:inline>
    // Filtering and Search Logic
    document.addEventListener('DOMContentLoaded', () => {
      const filterBtns = document.querySelectorAll('.filter-btn');
      const searchInput = document.getElementById('searchInput');
      const cards = document.querySelectorAll('.product-card');
      const noResults = document.getElementById('noResults');
      
      let currentCategory = 'All';
      let currentSearch = '';

      function filterProducts() {
        let visibleCount = 0;
        
        cards.forEach(card => {
          const cat = card.getAttribute('data-category');
          const name = card.getAttribute('data-name');
          
          const matchCategory = currentCategory === 'All' || cat === currentCategory;
          const matchSearch = currentSearch === '' || name.includes(currentSearch || '');
          
          if (matchCategory && matchSearch) {
            card.style.display = '';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });
        
        noResults.style.display = visibleCount === 0 ? 'block' : 'none';
      }

      filterBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          filterBtns.forEach(b => {
            b.classList.remove('active');
            b.style.background = 'white';
            b.style.color = 'var(--color-text-secondary)';
            b.style.border = '1px solid var(--color-border)';
          });
          
          const target = e.currentTarget;

          target.classList.add('active');
          target.style.background = 'var(--color-primary)';
          target.style.color = 'white';
          target.style.border = '1px solid var(--color-primary)';
          
          currentCategory = target.getAttribute('data-category') || 'All';
          filterProducts();
        });
      });

      if (searchInput) {
        searchInput.addEventListener('input', (e) => {
          currentSearch = e.target.value.toLowerCase().trim();
          filterProducts();
        });
      }
    });

    // Modal Logic
    const modal = document.getElementById('productModal');
    
    window.openModal = function(productId) {
      const product = window.PRODUCTS_DATA.find(p => p.id === productId);
      if (!product) return;
      
      document.getElementById('modalTitle').textContent = product.name;
      document.getElementById('modalCategory').textContent = product.category;
      document.getElementById('modalDesc').textContent = product.description;

      const modalImage = document.getElementById('modalImage');
      modalImage.src = product.image;
      modalImage.alt = product.name;
      
      // Specs
      const specsContainer = document.getElementById('modalSpecs');
      specsContainer.innerHTML = '';

      Object.entries(product.specifications).forEach(([key, val]) => {
        const li = document.createElement('li');
        li.style.display = 'flex';
        li.style.justifyContent = 'space-between';
        li.style.gap = '1rem';
        li.style.fontSize = '0.875rem';
        li.style.borderBottom = '1px dashed var(--color-border)';
        li.style.paddingBottom = '0.25rem';
        li.innerHTML = `<span style="color: var(--color-text-muted);">${key}</span> <span style="color: var(--color-text-primary); font-weight: 500; text-align: right; max-width: 60%;">${val}</span>`;
        specsContainer.appendChild(li);
      });
      
      modal.classList.add('active');
      document.body.style.overflow = 'hidden';
    };
    
    window.closeModal = function() {
      modal.classList.remove('active');
      document.body.style.overflow = '';
    };
    
    // Close on backdrop click
    if (modal) {
      modal.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
      });
    }
    
    // Close on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal && modal.classList.contains('active')) {
        closeModal();
      }
    });
  </script>
</MainLayout>