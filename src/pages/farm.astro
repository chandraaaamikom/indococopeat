---
import MainLayout from '../layouts/MainLayout.astro';
import { farms, farmStatistics } from '../data/farms';
---

<MainLayout title="Our Farm & Supply Chain | INDOCOCOPEAT" currentPage="farm">
  <div class="page-content" style="background-color: var(--color-offwhite); min-height: 100vh;">
    
    <!-- Header -->
    <div class="container" style="padding-top: 4rem; padding-bottom: 2rem;">
      <div style="max-width: 700px;">
        <h1 style="font-family: var(--font-heading); font-size: 3rem; margin-bottom: 1rem; color: var(--color-primary);">Our Farm & Supply Chain</h1>
        <p style="color: var(--color-text-secondary); line-height: 1.6; font-size: 1.125rem;">
          From our farms in Indonesia to your business worldwide.<br/>We ensure traceability, quality and sustainability at every step.
        </p>
      </div>
    </div>

    <!-- Farm Showcase Grid -->
    <div class="container section" style="padding-top: 2rem;">
      <div class="farm-layout">
        
        <!-- Featured Farm (First item) -->
        {farms.length > 0 && (
          <div class="farm-card featured-farm reveal" style="grid-column: span 12; background: white; border-radius: 24px; overflow: hidden; display: flex; border: 1px solid var(--color-border); box-shadow: var(--shadow-md);">
            <div style="flex: 1.2; background-color: var(--color-light-gray); position: relative; min-height: 360px; display: flex; align-items: center; justify-content: center;">
              <span style="font-size: 6rem; color: var(--color-border);">🌴</span>
              <div style="position: absolute; top: 1.5rem; left: 1.5rem; background: rgba(26,54,38,0.8); color: white; padding: 0.375rem 1rem; border-radius: var(--radius-full); font-size: 0.75rem; font-weight: 600; display: flex; align-items: center; gap: 0.5rem; backdrop-filter: blur(4px);">
                <svg style="width: 14px; height: 14px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                {farms[0].province}, Indonesia
              </div>
            </div>
            
            <div style="flex: 1; padding: 3rem; display: flex; flex-direction: column;">
              <h2 style="font-family: var(--font-heading); font-size: 2rem; color: var(--color-primary); margin-bottom: 1rem;">{farms[0].name}</h2>
              <p style="color: var(--color-text-secondary); line-height: 1.6; margin-bottom: 2rem;">
                {farms[0].description}
              </p>
              
              <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2rem;">
                <div style="border: 1px solid var(--color-border); padding: 0.75rem 1rem; border-radius: 12px; display: flex; align-items: center; gap: 0.75rem; background: var(--color-offwhite);">
                  <div style="color: var(--color-secondary);">👥</div>
                  <div>
                    <div style="font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted);">Farmers</div>
                    <div style="font-weight: 600; color: var(--color-primary);">{farms[0].farmerCount}+</div>
                  </div>
                </div>
                
                <div style="border: 1px solid var(--color-border); padding: 0.75rem 1rem; border-radius: 12px; display: flex; align-items: center; gap: 0.75rem; background: var(--color-offwhite);">
                  <div style="color: var(--color-secondary);">📦</div>
                  <div>
                    <div style="font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text-muted);">Monthly Supply</div>
                    <div style="font-weight: 600; color: var(--color-primary);">{farms[0].monthlyProduction}</div>
                  </div>
                </div>
              </div>
              
              <div style="margin-top: auto;">
                <a href={farms[0].mapsUrl} target="_blank" rel="noopener noreferrer" class="btn" style="background: var(--color-primary); color: white; width: 100%; border-radius: 8px;">
                  View on Google Maps &rarr;
                </a>
              </div>
            </div>
          </div>
        )}

        <!-- Standard Farms (Remaining items) -->
        {farms.slice(1).map((farm) => (
          <div class="farm-card reveal" style="grid-column: span 4; background: white; border-radius: 20px; overflow: hidden; display: flex; flex-direction: column; border: 1px solid var(--color-border); box-shadow: var(--shadow-sm); transition: transform 0.3s, box-shadow 0.3s;">
            <div style="height: 180px; background-color: var(--color-light-gray); position: relative; display: flex; align-items: center; justify-content: center;">
              <span style="font-size: 3rem; color: var(--color-border);">🌴</span>
              <div style="position: absolute; top: 1rem; left: 1rem; background: rgba(26,54,38,0.8); color: white; padding: 0.25rem 0.75rem; border-radius: var(--radius-full); font-size: 0.625rem; font-weight: 600; display: flex; align-items: center; gap: 0.25rem;">
                <svg style="width: 10px; height: 10px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path></svg>
                {farm.province}
              </div>
            </div>
            
            <div style="padding: 1.5rem; flex-grow: 1; display: flex; flex-direction: column;">
              <h3 style="font-family: var(--font-heading); font-size: 1.25rem; color: var(--color-primary); margin-bottom: 0.5rem;">{farm.name}</h3>
              <p style="font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.6; margin-bottom: 1.5rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                {farm.description}
              </p>
              
              <div style="display: flex; gap: 0.5rem; margin-bottom: 1.5rem; border-top: 1px solid var(--color-light-gray); padding-top: 1rem;">
                <div style="flex: 1; text-align: center;">
                  <div style="font-size: 1.25rem; margin-bottom: 0.25rem;">👨‍🌾</div>
                  <div style="font-size: 0.625rem; text-transform: uppercase; color: var(--color-text-muted);">Farmers</div>
                  <div style="font-size: 0.875rem; font-weight: 600; color: var(--color-primary);">{farm.farmerCount}+</div>
                </div>
                <div style="width: 1px; background: var(--color-light-gray);"></div>
                <div style="flex: 1; text-align: center;">
                  <div style="font-size: 1.25rem; margin-bottom: 0.25rem;">📦</div>
                  <div style="font-size: 0.625rem; text-transform: uppercase; color: var(--color-text-muted);">Monthly</div>
                  <div style="font-size: 0.875rem; font-weight: 600; color: var(--color-primary);">{farm.monthlyProduction}</div>
                </div>
              </div>
              
              <div style="margin-top: auto;">
                <a href={farm.mapsUrl} target="_blank" rel="noopener noreferrer" style="color: var(--color-accent-warm); font-size: 0.875rem; font-weight: 600; display: inline-flex; align-items: center; gap: 0.25rem; text-decoration: none;">
                  View on Google Maps &rarr;
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Supply Chain Process Section -->
    <div class="container section">
      <h2 style="font-family: var(--font-heading); font-size: 2rem; color: var(--color-primary); margin-bottom: 2rem;">Our Supply Chain Process</h2>
      
      <div class="process-cards" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem;">
        <div class="process-card" style="background: white; border: 1px solid var(--color-border); border-radius: 16px; padding: 2rem; position: relative;">
          <div style="width: 48px; height: 48px; background: var(--color-light-gray); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 1.5rem;">🌱</div>
          <h4 style="font-family: var(--font-heading); font-size: 1.125rem; color: var(--color-primary); margin-bottom: 0.5rem;">Sustainable Farming</h4>
          <p style="font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.6;">Coconuts are grown by our partner farmers using natural practices.</p>
          <div class="process-arrow hidden md-block" style="position: absolute; right: -1rem; top: 50%; transform: translateY(-50%); font-size: 1.25rem; color: var(--color-border); z-index: 10;">&rarr;</div>
        </div>
        
        <div class="process-card" style="background: white; border: 1px solid var(--color-border); border-radius: 16px; padding: 2rem; position: relative;">
          <div style="width: 48px; height: 48px; background: var(--color-light-gray); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 1.5rem;">🚜</div>
          <h4 style="font-family: var(--font-heading); font-size: 1.125rem; color: var(--color-primary); margin-bottom: 0.5rem;">Raw Material Collection</h4>
          <p style="font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.6;">Husks are collected and transported to our processing facility.</p>
          <div class="process-arrow hidden md-block" style="position: absolute; right: -1rem; top: 50%; transform: translateY(-50%); font-size: 1.25rem; color: var(--color-border); z-index: 10;">&rarr;</div>
        </div>

        <div class="process-card" style="background: white; border: 1px solid var(--color-border); border-radius: 16px; padding: 2rem; position: relative;">
          <div style="width: 48px; height: 48px; background: var(--color-light-gray); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 1.5rem;">⚙️</div>
          <h4 style="font-family: var(--font-heading); font-size: 1.125rem; color: var(--color-primary); margin-bottom: 0.5rem;">Processing & Quality Check</h4>
          <p style="font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.6;">Advanced processing with strict quality control at every stage.</p>
          <div class="process-arrow hidden md-block" style="position: absolute; right: -1rem; top: 50%; transform: translateY(-50%); font-size: 1.25rem; color: var(--color-border); z-index: 10;">&rarr;</div>
        </div>

        <div class="process-card" style="background: white; border: 1px solid var(--color-border); border-radius: 16px; padding: 2rem;">
          <div style="width: 48px; height: 48px; background: var(--color-light-gray); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 1.5rem;">🚢</div>
          <h4 style="font-family: var(--font-heading); font-size: 1.125rem; color: var(--color-primary); margin-bottom: 0.5rem;">Packing & Delivery</h4>
          <p style="font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.6;">Products are packed carefully and shipped worldwide.</p>
        </div>
      </div>
    </div>
  </div>

  <style>
    .farm-layout {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 1.5rem;
    }
    .farm-card:hover:not(.featured-farm) {
      transform: translateY(-4px);
      box-shadow: var(--shadow-md) !important;
    }

    @media (max-width: 1024px) {
      .featured-farm {
        flex-direction: column !important;
      }
      .featured-farm > div:first-child {
        min-height: 240px !important;
      }
      .farm-card {
        grid-column: span 6 !important;
      }
      .process-cards {
        grid-template-columns: repeat(2, 1fr) !important;
      }
    }
    
    @media (max-width: 768px) {
      .farm-card {
        grid-column: span 12 !important;
      }
      .process-cards {
        grid-template-columns: 1fr !important;
      }
    }
  </style>
</MainLayout>
